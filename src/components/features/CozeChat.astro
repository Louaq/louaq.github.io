---
interface Props {
    botId: string;
    token: string;
    title?: string;
    lang?: string;
    icon?: string;
}
const { botId, token, title = "AI 助手", lang = "zh-CN", icon } = Astro.props;
---

<script
    is:inline
    src="https://lf-cdn.coze.cn/obj/unpkg/flow-platform/chat-app-sdk/1.2.0-beta.17/libs/cn/index.js"
></script>

<script is:inline data-swup-ignore-script define:vars={{ botId, token, title, lang, icon }}>
(function () {
    // 屏蔽 Coze SDK 内部的 PressureObserver 权限错误（无害，仅影响控制台输出）
    const _origError = window.onerror;
    window.addEventListener("unhandledrejection", function (e) {
        if (e.reason && e.reason.name === "NotAllowedError" &&
            String(e.reason.message).includes("compute pressure")) {
            e.preventDefault();
        }
    });

    function initCoze() {
        if (typeof CozeWebSDK === "undefined") return;
        new CozeWebSDK.WebChatClient({
            config: {
                type: "bot",
                bot_id: botId,
                isIframe: false,
            },
            auth: {
                type: "token",
                token: token,
                onRefreshToken: () => token,
            },
            userInfo: {
                id: "blog_visitor",
                nickname: "访客",
            },
            ui: {
                base: {
                    layout: "pc",
                    lang: lang,
                    zIndex: 999,
                    ...(icon ? { icon } : {}),
                },
                header: {
                    isShow: true,
                    isNeedClose: true,
                    title: title,
                },
                asstBtn: {
                    isNeed: true,
                },
                chatBot: {
                    uploadable: false,
                },
            },
        });

        // 将悬浮按钮移到左下角
        function moveToBottomLeft(el) {
            const computed = getComputedStyle(el);
            if (computed.position === "fixed" && computed.bottom !== "auto") {
                el.style.right = "auto";
                el.style.left = "20px";
            }
        }
        const observer = new MutationObserver((mutations) => {
            for (const m of mutations) {
                m.addedNodes.forEach((node) => {
                    if (node.nodeType !== 1) return;
                    moveToBottomLeft(node);
                    node.querySelectorAll && node.querySelectorAll("*").forEach(moveToBottomLeft);
                });
            }
        });
        observer.observe(document.body, { childList: true, subtree: true });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCoze);
    } else {
        initCoze();
    }
})();
</script>
