---
import { Icon } from "astro-icon/components";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import { profileConfig } from "@/config/profileConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getCategoryList, getTagList } from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

/** 站内路径走 BASE_URL，外链/raw mailto 原样 */
function resolveProfileHref(href?: string): string | undefined {
	const h = href?.trim();
	if (!h) return undefined;
	if (/^https?:\/\//i.test(h) || h.startsWith("mailto:")) return h;
	return url(h.startsWith("/") ? h : `/${h}`);
}

const level = profileConfig.level?.trim();
const coverSrc = profileConfig.cover?.trim();
const menuHref = resolveProfileHref(profileConfig.menuHref) ?? url("/about/");
const verified = profileConfig.verified === true;

const tags = await getTagList();
const categories = await getCategoryList();
const tagCount = tags.length;
const categoryCount = categories.length;

const githubItem = profileConfig.links.find(
	(l) => /github\.com/i.test(l.url) || (l.icon ?? "").toLowerCase().includes("github"),
);
const emailItem = profileConfig.links.find((l) => l.url.startsWith("mailto:"));

const primaryEmailEncoded =
	emailItem?.url.startsWith("mailto:")
		? Buffer.from(emailItem.url.replace("mailto:", "")).toString("base64")
		: undefined;

const iconLinks = profileConfig.links.filter((l) => l !== githubItem && l !== emailItem);
---

<div class="card-base profile-card-hero overflow-hidden p-0 rounded-2xl shadow-sm border border-black/[0.06] dark:border-white/10">
  <!-- 头图区 -->
  <div class="profile-cover-wrap relative h-[6.5rem]">
    {
      coverSrc ? (
        <div
          class="absolute inset-0 bg-cover bg-center"
          style={`background-image:url(${JSON.stringify(coverSrc)})`}
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-slate-500 via-slate-600 to-slate-800" />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/25 to-transparent"
      aria-hidden="true"
    />

    <div
      class="profile-hero-avatar absolute left-4 bottom-0 z-20 block h-16 w-16 translate-y-1/2 rounded-full"
    >
      <div class="relative h-full w-full overflow-hidden rounded-full">
        <ImageWrapper
          src={profileConfig.avatar || ""}
          alt="Profile Image of the Author"
          class="h-full w-full object-cover"
        />
      </div>
      {
        verified && (
          <span
            class="pointer-events-none absolute bottom-0 right-0 z-30 flex h-5 w-5 translate-x-0.5 translate-y-0.5 items-center justify-center rounded-full border-2 border-white bg-[var(--juejin-primary,#1e80ff)] text-[10px] font-extrabold leading-none text-white shadow-sm dark:border-neutral-900"
            aria-label="verified"
          >
            V
          </span>
        )
      }
    </div>

    <div class="absolute bottom-2.5 left-0 right-3 z-10 min-w-0 pl-[5.25rem] text-white">
      <div class="flex flex-wrap items-center gap-2">
        <span
          class="profile-hero-name truncate text-lg font-bold leading-snug text-white drop-shadow-sm"
        >
          {profileConfig.name}
        </span>
        {
          level && (
            <span
              class="inline-flex shrink-0 items-center rounded px-1.5 py-0 text-[11px] font-semibold leading-5 text-white/95 ring-1 ring-white/35 bg-white/15"
              aria-label={`等级 ${level}`}
            >
              {level}
            </span>
          )
        }
      </div>
      <div class="mt-1 flex flex-wrap gap-x-4 gap-y-0.5 text-sm text-white/90">
        <span class="transition">
          {tagCount} {i18n(I18nKey.tags)}
        </span>
        <span class="transition">
          {categoryCount} {i18n(I18nKey.categories)}
        </span>
      </div>
    </div>
  </div>

  <!-- 白色内容区 -->
  <div class="profile-hero-body px-4 pb-4 pt-10 dark:bg-transparent">
    {
      profileConfig.bio?.trim() && (
        <p
          class="text-[15px] leading-snug text-neutral-500 dark:text-neutral-400 line-clamp-3"
          title={profileConfig.bio}
        >
          {profileConfig.bio}
        </p>
      )
    }

    {
      (githubItem || emailItem || iconLinks.length > 0) && (
        <div class="profile-actions-row mt-4 flex flex-nowrap items-center gap-2 overflow-x-auto pb-0.5 min-h-10">
          {
            githubItem && (
              <a
                href={githubItem.url}
                target="_blank"
                rel="me noopener noreferrer"
                class="profile-link-btn shrink-0"
                aria-label={githubItem.name}
                title={githubItem.name}
              >
                <Icon name="fa6-brands:github" class="text-xl" aria-hidden="true" />
              </a>
            )
          }
          {
            emailItem &&
              (primaryEmailEncoded ? (
                <a
                  rel="me"
                  aria-label={emailItem.name}
                  href="#"
                  data-encoded-email={primaryEmailEncoded}
                  onclick={`
                (function() {
                  const encodedEmail = this.getAttribute('data-encoded-email');
                  const decodedEmail = atob(encodedEmail);
                  this.href = 'mailto:' + decodedEmail;
                  this.removeAttribute('data-encoded-email');
                  this.removeAttribute('onclick');
                  this.click();
                  return false;
                }).call(this);
              `
                    .replace(/\s+/g, " ")
                    .trim()}
                  class:list={["profile-link-btn shrink-0"]}
                  title={emailItem.name}
                >
                  <Icon name="mdi:email" class="text-xl" aria-hidden="true" />
                </a>
              ) : (
                <a
                  href={emailItem.url}
                  class:list={["profile-link-btn shrink-0"]}
                  aria-label={emailItem.name}
                  title={emailItem.name}
                >
                  <Icon name="mdi:email" class="text-xl" aria-hidden="true" />
                </a>
              ))
          }
          {iconLinks.map((item) => {
            if (item.url.startsWith("mailto:")) {
              const encodedEmail = Buffer.from(
                item.url.replace("mailto:", ""),
              ).toString("base64");
              return (
                <a
                  rel="me"
                  aria-label={item.name}
                  href="#"
                  data-encoded-email={encodedEmail}
                  onclick={`
                (function() {
                  const encodedEmail = this.getAttribute('data-encoded-email');
                  const decodedEmail = atob(encodedEmail);
                  this.href = 'mailto:' + decodedEmail;
                  this.removeAttribute('data-encoded-email');
                  this.removeAttribute('onclick');
                  this.click();
                  return false;
                }).call(this);
              `
                    .replace(/\s+/g, " ")
                    .trim()}
                  class="profile-link-btn shrink-0"
                  title={item.name}
                >
                  <Icon name={item.icon} class="text-xl" />
                </a>
              );
            }
            const isExt = /^https?:/i.test(item.url);
            return (
              <a
                rel="me"
                aria-label={item.name}
                href={item.url}
                target={isExt ? "_blank" : undefined}
                class="profile-link-btn shrink-0"
                title={item.name}
              >
                <Icon name={item.icon} class="text-xl" />
              </a>
            );
          })}
        </div>
      )
    }
  </div>
</div>

<style is:global>
  /* 社交行：浅灰圆角底 + 图标色随 --primary / 色相滑块 */
  .profile-card-hero .profile-link-btn {
    width: 40px;
    height: 40px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5em;
    background: rgba(0, 0, 0, 0.055);
    color: var(--primary);
    border: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  :root.dark .profile-card-hero .profile-link-btn {
    background: rgba(255, 255, 255, 0.07);
  }

  .profile-card-hero .profile-link-btn:hover {
    background: rgba(0, 0, 0, 0.09);
    color: var(--juejin-primary-hover);
  }

  :root.dark .profile-card-hero .profile-link-btn:hover {
    background: rgba(255, 255, 255, 0.11);
  }
</style>
