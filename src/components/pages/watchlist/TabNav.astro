---
interface Tab {
	id: string;
	name: string;
	count?: number;
}

interface Props {
	tabs: Tab[];
	activeTab: string;
}

const { tabs, activeTab } = Astro.props;
---

<div class="border-b border-gray-200 dark:border-gray-700 mb-6">
  <nav class="flex space-x-8" aria-label="Tabs">
    {tabs.map((tab) => (
      <button
        class:list={[
          "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200",
          {
            "border-[var(--primary)] text-[var(--primary)]": tab.id === activeTab,
            "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300": tab.id !== activeTab
          }
        ]}
        data-tab={tab.id}
        type="button"
      >
        {tab.name}
        {tab.count !== undefined && (
          <span class="ml-2 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 py-0.5 px-2 rounded-full text-xs">
            {tab.count}
          </span>
        )}
      </button>
    ))}
  </nav>
</div>

<script>
  let tabNavAbort: AbortController | null = null;

  function getValidTabIds(): string[] {
    return Array.from(document.querySelectorAll("[data-tab]"))
      .map((el) => (el as HTMLButtonElement).dataset.tab)
      .filter((id): id is string => Boolean(id));
  }

  function applyWatchlistTab(tabId: string | undefined, syncHash: boolean) {
    const validIds = getValidTabIds();
    if (validIds.length === 0) return;

    const resolved =
      tabId && validIds.includes(tabId) ? tabId : validIds[0];
    if (!resolved) return;

    const tabButtons = document.querySelectorAll("[data-tab]");
    const sections = document.querySelectorAll("[data-section]");

    tabButtons.forEach((btn) => {
      const isActive = (btn as HTMLButtonElement).dataset.tab === resolved;
      if (isActive) {
        btn.classList.remove(
          "border-transparent",
          "text-gray-500",
          "hover:text-gray-700",
          "hover:border-gray-300",
          "dark:text-gray-400",
          "dark:hover:text-gray-300",
        );
        btn.classList.add(
          "border-[var(--primary)]",
          "text-[var(--primary)]",
        );
      } else {
        btn.classList.remove(
          "border-[var(--primary)]",
          "text-[var(--primary)]",
        );
        btn.classList.add(
          "border-transparent",
          "text-gray-500",
          "hover:text-gray-700",
          "hover:border-gray-300",
          "dark:text-gray-400",
          "dark:hover:text-gray-300",
        );
      }
    });

    sections.forEach((section) => {
      const htmlSection = section as HTMLElement;
      if (htmlSection.dataset.section === resolved) {
        htmlSection.classList.remove("hidden");
      } else {
        htmlSection.classList.add("hidden");
      }
    });

    if (syncHash) {
      const next = `#${resolved}`;
      if (location.hash !== next) {
        history.replaceState(null, "", next);
      }
    }
  }

  function initTabNavigation() {
    tabNavAbort?.abort();
    tabNavAbort = new AbortController();
    const { signal } = tabNavAbort;

    const hashTab = location.hash.slice(1).replace(/^\/+|\/+$/g, "");
    applyWatchlistTab(hashTab || undefined, false);
    document.documentElement.removeAttribute("data-watchlist-restore");

    document.querySelectorAll("[data-tab]").forEach((button) => {
      button.addEventListener(
        "click",
        (event) => {
          const targetTab = (event.currentTarget as HTMLButtonElement).dataset
            .tab;
          if (!targetTab) return;
          applyWatchlistTab(targetTab, true);
        },
        { signal },
      );
    });

    window.addEventListener(
      "hashchange",
      () => {
        const id = location.hash.slice(1).replace(/^\/+|\/+$/g, "");
        applyWatchlistTab(id || undefined, false);
      },
      { signal },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTabNavigation);
  } else {
    initTabNavigation();
  }

  document.addEventListener("astro:page-load", initTabNavigation);
</script>

