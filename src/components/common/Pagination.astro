---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { url } from "@/utils/url-utils";

interface Props {
	page: Page;
	class?: string;
	style?: string;
	pageUrlRoot?: string;
}

const { page, style, pageUrlRoot = "" } = Astro.props;
const className = Astro.props.class;

const root = pageUrlRoot.replace(/^\/+|\/+$/g, "");

const getPageUrl = (p: number) => {
	if (!root) {
		if (p === 1) return url("/");
		return url(`/${p}/`);
	}
	if (p === 1) return url(`/${root}/`);
	return url(`/${root}/${p}/`);
};

type PageItem = { kind: "page"; num: number } | { kind: "ellipsis" };

function buildPageItems(current: number, last: number): PageItem[] {
	if (last <= 1) return [];
	if (last <= 9) {
		return Array.from({ length: last }, (_, i) => ({
			kind: "page" as const,
			num: i + 1,
		}));
	}
	const items: PageItem[] = [];
	const delta = 1;
	const left = Math.max(2, current - delta);
	const right = Math.min(last - 1, current + delta);
	items.push({ kind: "page", num: 1 });
	if (left > 2) items.push({ kind: "ellipsis" });
	for (let i = left; i <= right; i++) {
		items.push({ kind: "page", num: i });
	}
	if (right < last - 1) items.push({ kind: "ellipsis" });
	items.push({ kind: "page", num: last });
	return items;
}

const pageItems = buildPageItems(page.currentPage, page.lastPage);
const baseUrl = import.meta.env.BASE_URL;

const navArrowClass =
	"inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--juejin-border)] bg-[var(--juejin-tag-bg)] text-[var(--juejin-text-secondary)] transition-colors hover:bg-[var(--btn-plain-bg-hover)]";
const navArrowDisabledClass =
	"inline-flex h-9 w-9 shrink-0 cursor-not-allowed items-center justify-center rounded-lg border border-[var(--juejin-border)] bg-[var(--juejin-tag-bg)] text-[var(--juejin-text-tertiary)] opacity-70";
const pageNumBase =
	"inline-flex h-9 min-w-9 items-center justify-center rounded-lg border px-2 text-sm font-medium tabular-nums transition-colors";
const pageNumIdle = `${pageNumBase} border-[var(--juejin-border)] bg-[var(--card-bg)] text-[var(--juejin-text-primary)] hover:bg-[var(--btn-plain-bg-hover)]`;
const pageNumActive = `${pageNumBase} border-[var(--primary)] bg-[var(--primary)] text-white shadow-sm`;
const ellipsisClass =
	"flex h-9 items-center px-1 text-sm text-[var(--juejin-text-tertiary)] select-none";
const jumpGroupClass =
	"group/pjump pagination-jump-group ml-0.5 inline-flex max-w-full";
const jumpShellClass =
	"inline-flex h-9 overflow-hidden rounded-lg border border-[var(--juejin-border)] bg-[var(--card-bg)]";
const jumpInputSlotClass =
	"jump-input-slot max-w-0 overflow-hidden opacity-0 transition-[max-width,opacity] duration-300 ease-out motion-reduce:transition-none group-hover/pjump:max-w-12 group-hover/pjump:opacity-100 group-focus-within/pjump:max-w-12 group-focus-within/pjump:opacity-100";
const jumpInputClass =
	"box-border h-9 w-12 min-w-12 shrink-0 border-0 bg-transparent px-1 text-center text-sm text-[var(--juejin-text-primary)] tabular-nums outline-none focus:ring-0";
const jumpSubmitClass =
	"inline-flex h-9 shrink-0 items-center justify-center border-l border-[var(--juejin-border)] bg-[var(--juejin-tag-bg)] px-2 text-[var(--primary)] transition-colors hover:bg-[var(--btn-plain-bg-hover)]";

const jumpInputAria = [
	i18n(I18nKey.paginationJumpTo),
	i18n(I18nKey.paginationJumpPageUnit),
]
	.filter(Boolean)
	.join("");
---

{
	page.lastPage > 1 && (
		<div
			class:list={[className, "flex w-full max-w-full flex-col gap-1"]}
			style={style}
			data-static-pagination
			data-pagination-root={root}
			data-pagination-last-page={page.lastPage}
			data-pagination-current-page={page.currentPage}
			data-pagination-base-url={baseUrl}
			data-pagination-jump-invalid-msg={i18n(I18nKey.paginationJumpInvalid)}
		>
			<nav
				class="pagination-reflow flex w-full max-w-full flex-row items-center gap-2 sm:gap-3"
				aria-label="Pagination"
			>
				<div class="flex w-9 shrink-0 justify-start sm:w-10">
					{page.url.prev ? (
						<a
							href={page.url.prev}
							class={navArrowClass}
							aria-label={i18n(I18nKey.paginationPrev)}
						>
							<Icon
								name="material-symbols:chevron-left"
								class="text-[1.25rem] leading-none sm:text-[1.35rem]"
							/>
						</a>
					) : (
						<span
							class={navArrowDisabledClass}
							aria-disabled="true"
							aria-label={i18n(I18nKey.paginationPrev)}
						>
							<Icon
								name="material-symbols:chevron-left"
								class="text-[1.25rem] leading-none sm:text-[1.35rem]"
							/>
						</span>
					)}
				</div>

				<div class="flex min-w-0 flex-1 flex-wrap items-center justify-center gap-1.5">
					{pageItems.map((item) =>
						item.kind === "ellipsis" ? (
							<span class={ellipsisClass} aria-hidden="true">
								…
							</span>
						) : item.num === page.currentPage ? (
							<span
								class={pageNumActive}
								aria-current="page"
								aria-label={`${i18n(I18nKey.paginationPage)} ${item.num}`}
							>
								{item.num}
							</span>
						) : (
							<a
								href={getPageUrl(item.num)}
								class={pageNumIdle}
								aria-label={`${i18n(I18nKey.paginationPage)} ${item.num}`}
							>
								{item.num}
							</a>
						),
					)}

					<div class={jumpGroupClass} data-pagination-jump-shell>
						<div class={jumpShellClass}>
							<div class={jumpInputSlotClass}>
								<input
									type="text"
									inputmode="numeric"
									pattern="[0-9]*"
									autocomplete="off"
									enterkeyhint="go"
									maxlength={Math.max(1, String(page.lastPage).length)}
									class={jumpInputClass}
									data-pagination-jump-input
									aria-label={jumpInputAria || i18n(I18nKey.paginationJumpTo)}
								/>
							</div>
							<button
								type="button"
								class={jumpSubmitClass}
								data-pagination-jump-go
								aria-label={i18n(I18nKey.paginationGo)}
							>
								<Icon
									name="material-symbols:keyboard-double-arrow-right-rounded"
									class="text-[1.125rem] sm:text-[1.25rem]"
								/>
							</button>
						</div>
					</div>
				</div>

				<div class="flex w-9 shrink-0 justify-end sm:w-10">
					{page.url.next ? (
						<a
							href={page.url.next}
							class={navArrowClass}
							aria-label={i18n(I18nKey.paginationNext)}
						>
							<Icon
								name="material-symbols:chevron-right"
								class="text-[1.25rem] leading-none sm:text-[1.35rem]"
							/>
						</a>
					) : (
						<span
							class={navArrowDisabledClass}
							aria-disabled="true"
							aria-label={i18n(I18nKey.paginationNext)}
						>
							<Icon
								name="material-symbols:chevron-right"
								class="text-[1.25rem] leading-none sm:text-[1.35rem]"
							/>
						</span>
					)}
				</div>
			</nav>

			<p
				data-pagination-jump-error
				class="hidden w-full px-2 text-center text-sm text-red-600 dark:text-red-400"
				role="alert"
				aria-live="polite"
			/>
		</div>
	)
}

<script is:inline>
	(function () {
		function isCoarsePointer() {
			return window.matchMedia("(hover: none), (pointer: coarse)").matches;
		}
		function ensureJumpTouchOutsideClose() {
			if (window.__fireflyJumpTouchOutside) return;
			window.__fireflyJumpTouchOutside = true;
			document.addEventListener("click", function (e) {
				if (!isCoarsePointer()) return;
				const t = e.target;
				if (!(t instanceof Node)) return;
				document
					.querySelectorAll(".pagination-jump-group.jump-touch-expanded")
					.forEach((g) => {
						if (g instanceof HTMLElement && !g.contains(t)) {
							g.classList.remove("jump-touch-expanded");
						}
					});
			});
		}
		function joinUrlParts(...parts) {
			return parts.join("/").replace(/\/+/g, "/");
		}
		function buildPageUrl(root, pageNum, baseUrl) {
			const path = !root
				? pageNum === 1
					? "/"
					: `/${pageNum}/`
				: pageNum === 1
					? `/${root}/`
					: `/${root}/${pageNum}/`;
			return joinUrlParts("", baseUrl || "/", path);
		}
		function bindJump(wrap) {
			const input = wrap.querySelector("[data-pagination-jump-input]");
			const btn = wrap.querySelector("[data-pagination-jump-go]");
			const errEl = wrap.querySelector("[data-pagination-jump-error]");
			if (!(input instanceof HTMLInputElement) || !btn) return;
			const invalidMsg = wrap.dataset.paginationJumpInvalidMsg || "";
			const root = wrap.dataset.paginationRoot || "";
			const lastPage = Math.max(
				1,
				parseInt(String(wrap.dataset.paginationLastPage || "1"), 10) || 1,
			);
			const currentPage = Math.max(
				1,
				parseInt(String(wrap.dataset.paginationCurrentPage || "1"), 10) || 1,
			);
			const baseUrl = wrap.dataset.paginationBaseUrl || "/";
			const jumpGroup = wrap.querySelector("[data-pagination-jump-shell]");
			ensureJumpTouchOutsideClose();
			if (jumpGroup instanceof HTMLElement) {
				jumpGroup.addEventListener("click", function (e) {
					if (!isCoarsePointer()) return;
					if (jumpGroup.classList.contains("jump-touch-expanded")) return;
					const t = e.target;
					if (t instanceof Node && (btn.contains(t) || t === btn)) return;
					jumpGroup.classList.add("jump-touch-expanded");
					input.focus();
				});
			}
			function hideError() {
				if (errEl instanceof HTMLElement) {
					errEl.textContent = "";
					errEl.classList.add("hidden");
				}
				input.removeAttribute("aria-invalid");
			}
			function showError() {
				if (errEl instanceof HTMLElement && invalidMsg) {
					errEl.textContent = invalidMsg;
					errEl.classList.remove("hidden");
				}
				input.setAttribute("aria-invalid", "true");
			}
			function go() {
				hideError();
				const v = String(input.value).trim();
				if (v === "" || !/^\d+$/.test(v)) {
					showError();
					return;
				}
				const n = parseInt(v, 10);
				if (!Number.isFinite(n)) {
					showError();
					return;
				}
				const p = Math.min(lastPage, Math.max(1, n));
				if (p === currentPage) return;
				window.location.href = buildPageUrl(root, p, baseUrl);
			}
			btn.addEventListener("click", function () {
				if (
					jumpGroup instanceof HTMLElement &&
					isCoarsePointer() &&
					!jumpGroup.classList.contains("jump-touch-expanded")
				) {
					jumpGroup.classList.add("jump-touch-expanded");
					input.focus();
					return;
				}
				go();
			});
			input.addEventListener("input", hideError);
			input.addEventListener("keydown", function (e) {
				if (e.key === "Enter") {
					e.preventDefault();
					go();
				}
			});
		}
		function init() {
			document.querySelectorAll("[data-static-pagination]").forEach(bindJump);
		}
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>

<style>
	.pagination-reflow {
		flex-wrap: wrap;
		row-gap: 0.5rem;
	}
	@media (min-width: 480px) {
		.pagination-reflow {
			flex-wrap: nowrap;
		}
	}
	/* 触摸设备：由脚本添加 jump-touch-expanded，点按后展开 */
	.pagination-jump-group.jump-touch-expanded .jump-input-slot {
		max-width: 3rem;
		opacity: 1;
	}
</style>
