---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { url } from "@/utils/url-utils";

interface Props {
	page: Page;
	class?: string;
	style?: string;
	/** 分页根路径（不含末尾页码），如 "archive" 对应 /archive/、/archive/2/。缺省为首页 /、/2/ */
	pageUrlRoot?: string;
}

const { page, style, pageUrlRoot = "" } = Astro.props;
const className = Astro.props.class;

const root = pageUrlRoot.replace(/^\/+|\/+$/g, "");

const getPageUrl = (p: number) => {
	if (!root) {
		if (p === 1) return url("/");
		return url(`/${p}/`);
	}
	if (p === 1) return url(`/${root}/`);
	return url(`/${root}/${p}/`);
};

const firstPageHref = getPageUrl(1);
const lastPageHref = getPageUrl(page.lastPage);
const isFirst = page.currentPage === 1;
const isLast = page.currentPage === page.lastPage;

const compactLabel = i18n(I18nKey.paginationCompact)
	.replace("{current}", String(page.currentPage))
	.replace("{total}", String(page.lastPage));

const btnClass =
	"inline-flex items-center gap-1 px-1.5 py-2 -mx-0.5 text-sm text-[var(--primary)] hover:opacity-80 transition-opacity shrink-0 min-h-11 sm:min-h-12 sm:px-2 sm:py-2.5 sm:text-base";
const btnDisabledClass =
	"inline-flex items-center gap-1 px-1.5 py-2 -mx-0.5 text-sm text-[var(--primary)] opacity-40 pointer-events-none cursor-not-allowed shrink-0 min-h-11 sm:min-h-12 sm:px-2 sm:py-2.5 sm:text-base";
---

{
	page.lastPage > 1 && (
		<div
			class:list={[className, "flex w-full max-w-full flex-col items-center"]}
			style={style}
		>
			<nav
				class="flex w-full max-w-full flex-row flex-wrap items-center justify-center gap-x-2 gap-y-2 px-1 sm:gap-x-3"
				aria-label="Pagination"
			>
				{!isFirst ? (
					<a href={firstPageHref} class={btnClass}>
						<Icon
							name="material-symbols:first-page-rounded"
							class="text-[1.125rem] opacity-90 sm:text-[1.25rem]"
						/>
						{i18n(I18nKey.paginationFirst)}
					</a>
				) : (
					<span class={btnDisabledClass} aria-disabled="true">
						<Icon
							name="material-symbols:first-page-rounded"
							class="text-[1.125rem] sm:text-[1.25rem]"
						/>
						{i18n(I18nKey.paginationFirst)}
					</span>
				)}

				{page.url.prev ? (
					<a href={page.url.prev} class={btnClass}>
						<Icon
							name="material-symbols:chevron-left-rounded"
							class="text-[1.125rem] opacity-90 sm:text-[1.25rem]"
						/>
						{i18n(I18nKey.paginationPrev)}
					</a>
				) : (
					<span class={btnDisabledClass} aria-disabled="true">
						<Icon
							name="material-symbols:chevron-left-rounded"
							class="text-[1.125rem] sm:text-[1.25rem]"
						/>
						{i18n(I18nKey.paginationPrev)}
					</span>
				)}

				<span class="shrink text-sm font-medium text-neutral-800 dark:text-neutral-200 tabular-nums px-1 min-w-0 text-center sm:text-base">
					{compactLabel}
				</span>

				{page.url.next ? (
					<a href={page.url.next} class={btnClass}>
						{i18n(I18nKey.paginationNext)}
						<Icon
							name="material-symbols:chevron-right-rounded"
							class="text-[1.125rem] opacity-90 sm:text-[1.25rem]"
						/>
					</a>
				) : (
					<span class={btnDisabledClass} aria-disabled="true">
						{i18n(I18nKey.paginationNext)}
						<Icon
							name="material-symbols:chevron-right-rounded"
							class="text-[1.125rem] sm:text-[1.25rem]"
						/>
					</span>
				)}

				{!isLast ? (
					<a href={lastPageHref} class={btnClass}>
						{i18n(I18nKey.paginationLast)}
						<Icon
							name="material-symbols:last-page-rounded"
							class="text-[1.125rem] opacity-90 sm:text-[1.25rem]"
						/>
					</a>
				) : (
					<span class={btnDisabledClass} aria-disabled="true">
						{i18n(I18nKey.paginationLast)}
						<Icon
							name="material-symbols:last-page-rounded"
							class="text-[1.125rem] sm:text-[1.25rem]"
						/>
					</span>
				)}
			</nav>
		</div>
	)
}
