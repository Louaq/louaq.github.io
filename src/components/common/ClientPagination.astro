---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	totalItems: number;
	itemsPerPage: number;
	currentPage: number;
	sectionId: string;
}

const { totalItems, itemsPerPage, currentPage, sectionId } = Astro.props;
const totalPages = Math.ceil(totalItems / itemsPerPage);

const compactTemplate = i18n(I18nKey.paginationCompact);
const compactLabel = compactTemplate
	.replace("{current}", String(currentPage))
	.replace("{total}", String(totalPages));

const jumpUnit = i18n(I18nKey.paginationJumpPageUnit);
const hasJumpUnit = jumpUnit.length > 0;

const btnClass =
	"inline-flex items-center gap-1 px-1.5 py-2 -mx-0.5 text-sm text-[var(--primary)] hover:opacity-80 transition-opacity shrink-0 min-h-11 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:opacity-100";

const jumpInputClass =
	"w-14 min-w-12 max-w-24 rounded-md border border-[var(--line-divider)] bg-[var(--card-bg)] px-2 py-1.5 text-center text-sm font-medium text-neutral-800 tabular-nums outline-none transition-none dark:text-neutral-200 focus:border-[var(--line-divider)] focus:shadow-none focus:outline-none focus:ring-0 focus:ring-offset-0";
const jumpBtnClass =
	"shrink-0 border-0 bg-transparent px-1.5 py-2 min-h-11 text-sm text-[var(--primary)] hover:opacity-80 transition-opacity cursor-pointer disabled:cursor-not-allowed disabled:opacity-40";
---

{
	totalPages > 1 && (
		<div
			class="responsive-pagination mt-6 flex w-full max-w-full flex-col items-center"
			data-pagination-section={sectionId}
		>
			<nav
				class="flex w-full max-w-full flex-row flex-wrap items-center justify-center gap-x-2 gap-y-2 px-1 sm:gap-x-3"
				aria-label="Pagination"
			>
				<button
					type="button"
					class={btnClass}
					data-page="prev"
					data-section={sectionId}
					disabled={currentPage === 1}
					aria-label={i18n(I18nKey.bangumiPrevPage)}
				>
					<Icon
						name="material-symbols:chevron-left-rounded"
						class="text-[1.125rem] opacity-90"
					/>
					{i18n(I18nKey.paginationPrev)}
				</button>

				<span
					data-compact-label
					class="text-sm font-medium text-neutral-800 dark:text-neutral-200 tabular-nums px-1 min-w-0 text-center shrink"
				>
					{compactLabel}
				</span>

				<button
					type="button"
					class={btnClass}
					data-page="next"
					data-section={sectionId}
					disabled={currentPage === totalPages}
					aria-label={i18n(I18nKey.bangumiNextPage)}
				>
					{i18n(I18nKey.paginationNext)}
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="text-[1.125rem] opacity-90"
					/>
				</button>

				<form
					class="inline-flex max-w-full flex-wrap items-center gap-1.5 text-sm text-neutral-600 dark:text-neutral-400"
					data-client-pagination-jump
				>
					<label class="inline-flex min-w-0 max-w-full flex-wrap items-center gap-1.5">
						<input
							type="text"
							name="clientPage"
							class={jumpInputClass}
							data-jump-input
							data-jump-max={totalPages}
							inputmode="numeric"
							pattern="[0-9]*"
							autocomplete="off"
							maxlength={6}
							aria-label={compactLabel}
						/>
						{hasJumpUnit && (
							<span class="shrink-0 whitespace-nowrap">{jumpUnit}</span>
						)}
					</label>
					<button type="submit" class={jumpBtnClass} data-jump-submit>
						{i18n(I18nKey.paginationGo)}
					</button>
				</form>
			</nav>
		</div>
	)
}

<script
	is:inline
	define:vars={{
		itemsPerPage,
		sectionId,
		initialPage: currentPage,
		compactTemplate,
	}}
>
	function initPagination() {
		let currentPage = initialPage;
		let isInitialLoad = true;

		const pagination = document.querySelector(
			`[data-pagination-section="${sectionId}"]`,
		);
		if (!pagination) return;

		const jumpForm = pagination.querySelector(
			"[data-client-pagination-jump]",
		);
		const jumpInput = jumpForm
			? jumpForm.querySelector("[data-jump-input]")
			: null;

		function setCompactLabel(totalPages) {
			const el = pagination.querySelector("[data-compact-label]");
			if (el) {
				el.textContent = compactTemplate
					.replace("{current}", String(currentPage))
					.replace("{total}", String(totalPages));
			}
		}

		function setNavDisabled(totalPages) {
			pagination.querySelectorAll('[data-page="prev"]').forEach((btn) => {
				btn.disabled = currentPage === 1;
			});
			pagination.querySelectorAll('[data-page="next"]').forEach((btn) => {
				btn.disabled = currentPage === totalPages;
			});
		}

		function syncJumpInput(totalPages) {
			if (!jumpInput) return;
			jumpInput.setAttribute(
				"data-jump-max",
				String(Math.max(1, totalPages)),
			);
		}

		if (jumpForm) {
			jumpForm.addEventListener("submit", function (e) {
				e.preventDefault();
				if (!jumpInput) return;
				const n = parseInt(String(jumpInput.value).trim(), 10);
				if (!Number.isFinite(n)) return;
				const items = document.querySelectorAll(
					`[data-item-section="${sectionId}"]:not(.hidden)`,
				);
				const totalPages = Math.ceil(items.length / itemsPerPage);
				const maxP = Math.max(1, totalPages);
				currentPage = Math.max(1, Math.min(n, maxP));
				updatePage();
				jumpInput.value = "";
			});
		}

		pagination.querySelectorAll("[data-page]").forEach((button) => {
			button.addEventListener("click", function () {
				const page = this.dataset.page;
				if (page === "prev") {
					currentPage = Math.max(1, currentPage - 1);
				} else if (page === "next") {
					const items = document.querySelectorAll(
						`[data-item-section="${sectionId}"]:not(.hidden)`,
					);
					const totalPages = Math.ceil(items.length / itemsPerPage);
					currentPage = Math.min(totalPages, currentPage + 1);
				}
				updatePage();
			});
		});

		pagination.addEventListener("updatePagination", function () {
			currentPage = 1;
			if (jumpInput) jumpInput.value = "";
			updatePage();
		});

		function updatePage() {
			const items = document.querySelectorAll(
				`[data-item-section="${sectionId}"]:not(.hidden)`,
			);
			const totalPages = Math.ceil(items.length / itemsPerPage);

			if (currentPage > totalPages && totalPages > 0) {
				currentPage = totalPages;
			}

			const startIndex = (currentPage - 1) * itemsPerPage;
			const endIndex = startIndex + itemsPerPage;

			const applyVisibility = () => {
				for (const item of items) {
					item.style.display = "none";
				}
				for (let i = startIndex; i < endIndex && i < items.length; i++) {
					items[i].style.display = "block";
					items[i].style.opacity = "1";
				}
				setCompactLabel(totalPages);
				setNavDisabled(totalPages);
				syncJumpInput(totalPages);
			};

			if (isInitialLoad) {
				isInitialLoad = false;
				applyVisibility();
			} else {
				for (const item of items) {
					if (item.style.display !== "none") {
						item.style.opacity = "0";
					}
				}
				setTimeout(() => {
					applyVisibility();
				}, 200);
			}
		}

		updatePage();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initPagination);
	} else {
		initPagination();
	}
</script>

<style>
	.responsive-pagination {
		max-width: 100%;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
</style>
