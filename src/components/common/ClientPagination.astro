---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	totalItems: number;
	itemsPerPage: number;
	currentPage: number;
	sectionId: string;
}

const { totalItems, itemsPerPage, currentPage, sectionId } = Astro.props;
const totalPages = Math.ceil(totalItems / itemsPerPage);

type PageItem = { kind: "page"; num: number } | { kind: "ellipsis" };

function buildPageItems(cur: number, last: number): PageItem[] {
	if (last <= 1) return [];
	if (last <= 9) {
		return Array.from({ length: last }, (_, i) => ({
			kind: "page" as const,
			num: i + 1,
		}));
	}
	const items: PageItem[] = [];
	const delta = 1;
	const left = Math.max(2, cur - delta);
	const right = Math.min(last - 1, cur + delta);
	items.push({ kind: "page", num: 1 });
	if (left > 2) items.push({ kind: "ellipsis" });
	for (let i = left; i <= right; i++) {
		items.push({ kind: "page", num: i });
	}
	if (right < last - 1) items.push({ kind: "ellipsis" });
	items.push({ kind: "page", num: last });
	return items;
}

const pageItems = buildPageItems(currentPage, totalPages);

const navArrowClass =
	"inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--juejin-border)] bg-[var(--juejin-tag-bg)] text-[var(--juejin-text-secondary)] transition-colors hover:bg-[var(--btn-plain-bg-hover)] disabled:cursor-not-allowed disabled:opacity-50";
const pageNumBase =
	"inline-flex h-9 min-w-9 items-center justify-center rounded-lg border px-2 text-sm font-medium tabular-nums transition-colors";
const pageNumIdle = `${pageNumBase} border-[var(--juejin-border)] bg-[var(--card-bg)] text-[var(--juejin-text-primary)] hover:bg-[var(--btn-plain-bg-hover)]`;
const pageNumActive = `${pageNumBase} border-[var(--primary)] bg-[var(--primary)] text-white shadow-sm`;
const ellipsisClass =
	"flex h-9 items-center px-1 text-sm text-[var(--juejin-text-tertiary)] select-none";
const jumpGroupClass =
	"group/pjump pagination-jump-group ml-0.5 inline-flex max-w-full";
const jumpShellClass =
	"inline-flex h-9 overflow-hidden rounded-lg border border-[var(--juejin-border)] bg-[var(--card-bg)]";
const jumpInputSlotClass =
	"jump-input-slot max-w-0 overflow-hidden opacity-0 transition-[max-width,opacity] duration-300 ease-out motion-reduce:transition-none group-hover/pjump:max-w-12 group-hover/pjump:opacity-100 group-focus-within/pjump:max-w-12 group-focus-within/pjump:opacity-100";
const jumpInputClass =
	"box-border h-9 w-12 min-w-12 shrink-0 border-0 bg-transparent px-1 text-center text-sm text-[var(--juejin-text-primary)] tabular-nums outline-none focus:ring-0";
const jumpSubmitClass =
	"inline-flex h-9 shrink-0 items-center justify-center border-l border-[var(--juejin-border)] bg-[var(--juejin-tag-bg)] px-2 text-[var(--primary)] transition-colors hover:bg-[var(--btn-plain-bg-hover)] disabled:cursor-not-allowed disabled:opacity-50";

const jumpInvalidMsg = i18n(I18nKey.paginationJumpInvalid);
const jumpInputAria = [
	i18n(I18nKey.paginationJumpTo),
	i18n(I18nKey.paginationJumpPageUnit),
]
	.filter(Boolean)
	.join("");
---

{
	totalPages > 1 && (
		<div
			class="responsive-pagination mt-6 flex w-full max-w-full flex-col gap-1"
			data-pagination-section={sectionId}
		>
			<nav
				class="pagination-reflow flex w-full max-w-full flex-row items-center gap-2 sm:gap-3"
				aria-label="Pagination"
			>
				<div class="flex w-9 shrink-0 justify-start sm:w-10">
					<button
						type="button"
						class={navArrowClass}
						data-page="prev"
						data-section={sectionId}
						disabled={currentPage === 1}
						aria-label={i18n(I18nKey.paginationPrev)}
					>
						<Icon
							name="material-symbols:chevron-left"
							class="text-[1.25rem] leading-none sm:text-[1.35rem]"
						/>
					</button>
				</div>

				<div
					class="flex min-w-0 flex-1 flex-wrap items-center justify-center gap-1.5"
					data-page-numbers
				>
					{pageItems.map((item) =>
						item.kind === "ellipsis" ? (
							<span class={ellipsisClass} aria-hidden="true">
								…
							</span>
						) : item.num === currentPage ? (
							<span
								class={pageNumActive}
								aria-current="page"
								aria-label={`${i18n(I18nKey.paginationPage)} ${item.num}`}
							>
								{item.num}
							</span>
						) : (
							<button
								type="button"
								class:list={[pageNumIdle, "pagination-page-btn"]}
								data-page-num={item.num}
								aria-label={`${i18n(I18nKey.paginationPage)} ${item.num}`}
							>
								{item.num}
							</button>
						),
					)}

					<div class={jumpGroupClass} data-pagination-jump-shell>
						<div class={jumpShellClass}>
							<div class={jumpInputSlotClass}>
								<input
									type="text"
									inputmode="numeric"
									pattern="[0-9]*"
									autocomplete="off"
									enterkeyhint="go"
									maxlength={Math.max(1, String(totalPages).length)}
									class={jumpInputClass}
									data-pagination-jump-input
									aria-label={jumpInputAria || i18n(I18nKey.paginationJumpTo)}
								/>
							</div>
							<button
								type="button"
								class={jumpSubmitClass}
								data-pagination-jump-go
								disabled={totalPages <= 1}
								aria-label={i18n(I18nKey.paginationGo)}
							>
								<Icon
									name="material-symbols:keyboard-double-arrow-right-rounded"
									class="text-[1.125rem] sm:text-[1.25rem]"
								/>
							</button>
						</div>
					</div>
				</div>

				<div class="flex w-9 shrink-0 justify-end sm:w-10">
					<button
						type="button"
						class={navArrowClass}
						data-page="next"
						data-section={sectionId}
						disabled={currentPage === totalPages}
						aria-label={i18n(I18nKey.paginationNext)}
					>
						<Icon
							name="material-symbols:chevron-right"
							class="text-[1.25rem] leading-none sm:text-[1.35rem]"
						/>
					</button>
				</div>
			</nav>

			<p
				data-pagination-jump-error
				class="hidden w-full px-2 text-center text-sm text-red-600 dark:text-red-400"
				role="alert"
				aria-live="polite"
			/>
		</div>
	)
}

<script
	is:inline
	define:vars={{
		itemsPerPage,
		sectionId,
		initialPage: currentPage,
		jumpInvalidMsg,
		pageNumIdle,
		pageNumActive,
		ellipsisClass,
		paginationPagePrefix: i18n(I18nKey.paginationPage),
	}}
>
	function isCoarsePointer() {
		return window.matchMedia("(hover: none), (pointer: coarse)").matches;
	}
	function ensureJumpTouchOutsideClose() {
		if (window.__fireflyJumpTouchOutside) return;
		window.__fireflyJumpTouchOutside = true;
		document.addEventListener("click", function (e) {
			if (!isCoarsePointer()) return;
			const t = e.target;
			if (!(t instanceof Node)) return;
			document
				.querySelectorAll(".pagination-jump-group.jump-touch-expanded")
				.forEach((g) => {
					if (g instanceof HTMLElement && !g.contains(t)) {
						g.classList.remove("jump-touch-expanded");
					}
				});
		});
	}

	function buildPageItemsClient(current, last) {
		if (last <= 1) return [];
		if (last <= 9) {
			const out = [];
			for (let i = 1; i <= last; i++) {
				out.push({ kind: "page", num: i });
			}
			return out;
		}
		const items = [];
		const delta = 1;
		const left = Math.max(2, current - delta);
		const right = Math.min(last - 1, current + delta);
		items.push({ kind: "page", num: 1 });
		if (left > 2) items.push({ kind: "ellipsis" });
		for (let i = left; i <= right; i++) {
			items.push({ kind: "page", num: i });
		}
		if (right < last - 1) items.push({ kind: "ellipsis" });
		items.push({ kind: "page", num: last });
		return items;
	}

	function initPagination() {
		let currentPage = initialPage;
		let isInitialLoad = true;

		const pagination = document.querySelector(
			`[data-pagination-section="${sectionId}"]`,
		);
		if (!pagination) return;

		const pageHost = pagination.querySelector("[data-page-numbers]");
		if (!pageHost) return;

		const jumpShell = pageHost.querySelector("[data-pagination-jump-shell]");
		if (!(jumpShell instanceof HTMLElement)) return;

		ensureJumpTouchOutsideClose();
		jumpShell.addEventListener("click", function (e) {
			if (!isCoarsePointer()) return;
			if (jumpShell.classList.contains("jump-touch-expanded")) return;
			const goBtn = pagination.querySelector("[data-pagination-jump-go]");
			const t = e.target;
			if (
				t instanceof Node &&
				goBtn instanceof HTMLElement &&
				(goBtn.contains(t) || t === goBtn)
			) {
				return;
			}
			jumpShell.classList.add("jump-touch-expanded");
			const inp = pagination.querySelector("[data-pagination-jump-input]");
			if (inp instanceof HTMLInputElement) inp.focus();
		});

		function rebuildPageNumberControls(totalPages) {
			const tp = Math.max(1, totalPages);
			const list = buildPageItemsClient(currentPage, tp);
			const frag = document.createDocumentFragment();
			for (const it of list) {
				if (it.kind === "ellipsis") {
					const span = document.createElement("span");
					span.className = ellipsisClass;
					span.setAttribute("aria-hidden", "true");
					span.textContent = "…";
					frag.appendChild(span);
				} else if (it.num === currentPage) {
					const span = document.createElement("span");
					span.className = pageNumActive;
					span.setAttribute("aria-current", "page");
					span.setAttribute(
						"aria-label",
						`${paginationPagePrefix} ${it.num}`,
					);
					span.textContent = String(it.num);
					frag.appendChild(span);
				} else {
					const button = document.createElement("button");
					button.type = "button";
					button.className = `${pageNumIdle} pagination-page-btn`;
					button.dataset.pageNum = String(it.num);
					button.setAttribute(
						"aria-label",
						`${paginationPagePrefix} ${it.num}`,
					);
					button.textContent = String(it.num);
					frag.appendChild(button);
				}
			}
			while (pageHost.firstChild && pageHost.firstChild !== jumpShell) {
				pageHost.removeChild(pageHost.firstChild);
			}
			pageHost.insertBefore(frag, jumpShell);
		}

		function hideJumpError() {
			const errEl = pagination.querySelector("[data-pagination-jump-error]");
			const el = pagination.querySelector("[data-pagination-jump-input]");
			if (errEl instanceof HTMLElement) {
				errEl.textContent = "";
				errEl.classList.add("hidden");
			}
			if (el instanceof HTMLInputElement) {
				el.removeAttribute("aria-invalid");
			}
		}

		function showJumpError() {
			const errEl = pagination.querySelector("[data-pagination-jump-error]");
			const el = pagination.querySelector("[data-pagination-jump-input]");
			if (errEl instanceof HTMLElement && jumpInvalidMsg) {
				errEl.textContent = jumpInvalidMsg;
				errEl.classList.remove("hidden");
			}
			if (el instanceof HTMLInputElement) {
				el.setAttribute("aria-invalid", "true");
			}
		}

		function setNavDisabled(totalPages) {
			const tp = Math.max(1, totalPages);
			pagination.querySelectorAll('[data-page="prev"]').forEach((btn) => {
				btn.disabled = currentPage === 1;
			});
			pagination.querySelectorAll('[data-page="next"]').forEach((btn) => {
				btn.disabled = currentPage === tp;
			});
			const jumpGo = pagination.querySelector("[data-pagination-jump-go]");
			if (jumpGo instanceof HTMLButtonElement) {
				jumpGo.disabled = tp <= 1;
			}
			const jumpInput = pagination.querySelector(
				"[data-pagination-jump-input]",
			);
			if (jumpInput instanceof HTMLInputElement) {
				jumpInput.maxLength = Math.max(1, String(tp).length);
			}
		}

		function applyJump() {
			const jumpInput = pagination.querySelector(
				"[data-pagination-jump-input]",
			);
			if (!(jumpInput instanceof HTMLInputElement)) return;
			hideJumpError();
			const v = String(jumpInput.value).trim();
			if (v === "" || !/^\d+$/.test(v)) {
				showJumpError();
				return;
			}
			const items = document.querySelectorAll(
				`[data-item-section="${sectionId}"]:not(.hidden)`,
			);
			const tp = Math.max(1, Math.ceil(items.length / itemsPerPage));
			const n = parseInt(v, 10);
			if (!Number.isFinite(n)) {
				showJumpError();
				return;
			}
			currentPage = Math.min(tp, Math.max(1, n));
			jumpInput.value = "";
			updatePage();
		}

		pageHost.addEventListener("click", function (e) {
			const target = e.target;
			if (!(target instanceof Element)) return;
			const btn = target.closest("[data-page-num]");
			if (!(btn instanceof HTMLButtonElement)) return;
			const num = parseInt(btn.dataset.pageNum || "", 10);
			if (!Number.isFinite(num)) return;
			currentPage = num;
			updatePage();
		});

		const jumpGoBtn = pagination.querySelector("[data-pagination-jump-go]");
		const jumpInputEl = pagination.querySelector("[data-pagination-jump-input]");
		jumpGoBtn?.addEventListener("click", function () {
			if (
				isCoarsePointer() &&
				!jumpShell.classList.contains("jump-touch-expanded")
			) {
				jumpShell.classList.add("jump-touch-expanded");
				if (jumpInputEl instanceof HTMLInputElement) jumpInputEl.focus();
				return;
			}
			applyJump();
		});
		jumpInputEl?.addEventListener("keydown", function (e) {
			if (e.key === "Enter") {
				e.preventDefault();
				applyJump();
			}
		});
		jumpInputEl?.addEventListener("input", hideJumpError);

		pagination.querySelectorAll("[data-page]").forEach((button) => {
			button.addEventListener("click", function () {
				const page = this.dataset.page;
				if (page === "prev") {
					currentPage = Math.max(1, currentPage - 1);
				} else if (page === "next") {
					const items = document.querySelectorAll(
						`[data-item-section="${sectionId}"]:not(.hidden)`,
					);
					const totalPages = Math.ceil(items.length / itemsPerPage);
					currentPage = Math.min(
						Math.max(1, totalPages),
						currentPage + 1,
					);
				}
				updatePage();
			});
		});

		pagination.addEventListener("updatePagination", function () {
			currentPage = 1;
			updatePage();
		});

		function updatePage() {
			const items = document.querySelectorAll(
				`[data-item-section="${sectionId}"]:not(.hidden)`,
			);
			const totalPages = Math.ceil(items.length / itemsPerPage);

			if (currentPage > totalPages && totalPages > 0) {
				currentPage = totalPages;
			}

			const startIndex = (currentPage - 1) * itemsPerPage;
			const endIndex = startIndex + itemsPerPage;

			const applyVisibility = () => {
				for (const item of items) {
					item.style.display = "none";
				}
				for (let i = startIndex; i < endIndex && i < items.length; i++) {
					items[i].style.display = "block";
					items[i].style.opacity = "1";
				}
				rebuildPageNumberControls(Math.max(1, totalPages));
				setNavDisabled(totalPages);
			};

			if (isInitialLoad) {
				isInitialLoad = false;
				applyVisibility();
			} else {
				for (const item of items) {
					if (item.style.display !== "none") {
						item.style.opacity = "0";
					}
				}
				setTimeout(() => {
					applyVisibility();
				}, 200);
			}
		}

		updatePage();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initPagination);
	} else {
		initPagination();
	}
</script>

<style>
	.responsive-pagination {
		max-width: 100%;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.pagination-reflow {
		flex-wrap: wrap;
		row-gap: 0.5rem;
	}
	@media (min-width: 480px) {
		.pagination-reflow {
			flex-wrap: nowrap;
		}
	}
	.pagination-jump-group.jump-touch-expanded .jump-input-slot {
		max-width: 3rem;
		opacity: 1;
	}
</style>
