---
import SearchAlgolia from "./SearchAlgolia.svelte";

interface Props {
	engine?: "algolia" | "milisearch";
}

const { engine } = Astro.props;
---

<!-- client:only：避免 SearchAlgolia 注水失败（多根节点 / portal / chunk 与 SSR 不一致）；首屏搜索槽可能短暂为空直至 JS 就绪 -->
<div class="navbar-search-slot">
	<SearchAlgolia engine={engine} client:only="svelte" />
</div>
