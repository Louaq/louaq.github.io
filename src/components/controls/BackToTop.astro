---
import FloatingButton from "@/components/common/FloatingButton.astro";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div id="back-to-top-wrapper" class="back-to-top-wrapper hide">
  <FloatingButton
    id="back-to-top-btn"
    icon="material-symbols:keyboard-arrow-up-rounded"
    ariaLabel="Back to Top"
    onclick="backToTop()"
    class=""
  />
</div>

<script is:raw is:inline>
  function backToTop() {
    // 直接使用原生滚动，避免OverlayScrollbars冲突
    window.scroll({ top: 0, behavior: "smooth" });
  }

  // 响应式返回顶部按钮管理器
  if (typeof window.BackToTopManager === "undefined") {
    window.BackToTopManager = class BackToTopManager {
      constructor() {
        this.wrapper = document.getElementById("back-to-top-wrapper");
        this.button = document.getElementById("back-to-top-btn");
        this.init();
      }

      init() {
        if (!this.button || !this.wrapper) return;

        this.setupScrollListener();
      }

      setupScrollListener() {
        const updateVisibility = () => {
          const scrollTop =
            window.pageYOffset || document.documentElement.scrollTop;

          // 当滚动超过200px时显示按钮
          if (scrollTop > 200) {
            this.wrapper.classList.remove("hide");
          } else {
            this.wrapper.classList.add("hide");
          }
        };

        window.addEventListener("scroll", updateVisibility, { passive: true });
        window.addEventListener("load", updateVisibility);
        window.addEventListener("pageshow", updateVisibility);
        updateVisibility();
        // 浏览器恢复滚动位置常在首帧布局之后，双 rAF 对齐 scroll restoration 时机
        requestAnimationFrame(() => {
          requestAnimationFrame(updateVisibility);
        });
      }
    };
  }

  function initBackToTopManager() {
    new BackToTopManager();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackToTopManager, {
      once: true,
    });
  } else {
    initBackToTopManager();
  }
</script>

<style is:global>
  #back-to-top-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    min-width: 3rem;
    max-width: 3rem;
    min-height: 3rem;
    max-height: 3rem;
    flex-shrink: 0;
    opacity: 1;
    pointer-events: auto;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #back-to-top-wrapper.hide {
    transform: scale(0.5);
    opacity: 0;
    pointer-events: none;
    height: 0 !important;
    width: 0 !important;
    margin: 0 !important;
    border-width: 0 !important;
    padding: 0 !important;
  }

  #back-to-top-wrapper #back-to-top-btn {
    width: 100%;
    height: 100%;
  }

  /* 响应式调整 - 与 FloatingButton 保持一致 */
  @media (max-width: 768px) {
    #back-to-top-wrapper {
      width: 3rem;
      height: 3rem;
      min-width: 3rem;
      max-width: 3rem;
      min-height: 3rem;
      max-height: 3rem;
    }
  }

  @media (max-width: 480px) {
    #back-to-top-wrapper {
      width: 2.5rem;
      height: 2.5rem;
      min-width: 2.5rem;
      max-width: 2.5rem;
      min-height: 2.5rem;
      max-height: 2.5rem;
    }
  }

  @media (max-width: 360px) {
    #back-to-top-wrapper {
      width: 2rem;
      height: 2rem;
      min-width: 2rem;
      max-width: 2rem;
      min-height: 2rem;
      max-height: 2rem;
    }
  }

  @media (max-width: 320px) {
    #back-to-top-wrapper {
      width: 1.75rem;
      height: 1.75rem;
      min-width: 1.75rem;
      max-width: 1.75rem;
      min-height: 1.75rem;
      max-height: 1.75rem;
    }
  }
</style>