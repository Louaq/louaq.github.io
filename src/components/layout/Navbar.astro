---
import { Icon } from "astro-icon/components";
import DisplaySettings from "@/components/controls/DisplaySettingsIntegrated.svelte";
import SearchAlgoliaLazy from "@/components/controls/SearchAlgoliaLazy.astro";
import { backgroundWallpaper, navBarConfig, siteConfig } from "@/config";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { isHomePage } from "@/utils/layout-utils";
import { url } from "@/utils/url-utils";
import DropdownMenu from "./DropdownMenu.astro";
import NavMenuPanel from "./NavMenuPanel.astro";

const className = Astro.props.class;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	backgroundWallpaper.mode === "banner"
		? backgroundWallpaper.banner?.navbar?.transparentMode || "semi"
		: "semi";

// 获取导航栏毛玻璃效果配置
const navbarEnableBlur =
	backgroundWallpaper.mode === "banner"
		? (backgroundWallpaper.banner?.navbar?.enableBlur ?? true)
		: false;

// 获取导航栏模糊度
const navbarBlur =
	backgroundWallpaper.mode === "banner"
		? (backgroundWallpaper.banner?.navbar?.blur ?? 20)
		: 0;

// 检查是否为首页
const isHomePageCheck = isHomePage(Astro.url.pathname);

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);
---
<div id="navbar" class="z-50" style={`--navbar-glass-blur: ${navbarBlur}px;`} data-transparent-mode={navbarTransparentMode} data-enable-blur={String(navbarEnableBlur)} data-is-home={isHomePageCheck}>
    <div class:list={[
        className,
        "!overflow-visible relative h-[4.5rem] mx-auto w-full",
    ]}>
        <div class="mx-auto flex h-full w-full min-w-0 max-w-[var(--page-width)] px-2 md:px-4">
        <div
            class:list={[
                "navbar-row flex h-full w-full min-w-0 items-center justify-between gap-2",
            ]}
        >
        <div class="flex min-w-0 max-w-full flex-1 items-center gap-2 lg:flex-none lg:gap-3 xl:gap-4">
        <a
            href={url('/')}
            aria-label="Go to Home Page"
            class:list={[
                "navbar-brand-link btn-plain rounded-lg h-[3.25rem] max-lg:min-w-0 max-lg:shrink px-5 max-lg:px-4 lg:shrink-0",
                siteConfig.navbar.followTheme && "navbar-brand-link--follow-theme",
            ]}
        >
            <div class:list={[
                "flex min-w-0 flex-row items-center justify-center text-[16px]",
                siteConfig.navbar.followTheme ? "text-[var(--primary)]" : "dark:text-white",
            ]}>
                                {siteConfig.navbar.logo?.type === "icon" ? (
                                    <Icon name={siteConfig.navbar.logo.value || "material-symbols:home-pin-outline"} class="shrink-0 text-[1.75rem]" />
                                ) : siteConfig.navbar.logo?.type === "image" ? (
                                    <img src={url(siteConfig.navbar.logo.value)} alt="" class="h-[1.75rem] w-[1.75rem] shrink-0 object-contain" loading="eager" />
                                ) : siteConfig.navbar.logo?.type === "url" ? (
                                    <img src={siteConfig.navbar.logo.value} alt="" class="h-7 w-7 shrink-0 object-contain" fetchpriority="high" />
                                ) : (
                                    <Icon name="material-symbols:home-pin-outline" class="shrink-0 text-[1.75rem]" />
                                )}
            </div>
        </a>
        <div
            class:list={[
                "hidden min-w-0 items-center space-x-1 lg:flex",
            ]}
        >
            {links.map((l) => {
                return <DropdownMenu link={l} />;
            })}
        </div>
        </div>
        <div class="flex shrink-0 items-center">
            <SearchAlgoliaLazy engine={siteConfig.search?.engine} />
            {!siteConfig.themeColor.fixed ? (
                <div class="relative shrink-0">
                    <button aria-label="Display Settings" class="navbar-util-no-hover btn-plain rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
                    <DisplaySettings client:only="svelte"></DisplaySettings>
                </div>
            ) : null}
            {(siteConfig.themeColor.showModeSwitch ?? true) && (
                <button
                    aria-label="Toggle Light/Dark Mode"
                    class="navbar-util-no-hover relative btn-plain rounded-lg h-11 w-11 active:scale-90"
                    id="scheme-switch"
                    type="button"
                >
                    <span class="theme-icon theme-icon-light" aria-hidden="true">
                        <Icon name="material-symbols:wb-sunny-outline-rounded" class="text-[1.25rem]" />
                    </span>
                    <span class="theme-icon theme-icon-dark" aria-hidden="true">
                        <Icon name="material-symbols:dark-mode-outline-rounded" class="text-[1.25rem]" />
                    </span>
                </button>
            )}
            <button aria-label="Menu" name="Nav Menu" class="navbar-util-no-hover btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 lg:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        </div>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
    </div>
</div>

<script>
const NAVBAR_ACTIVE_CLASS = "navbar-link-active";

function normalizeNavPath(path: string) {
    const pathname = (() => {
        try {
            return new URL(path, window.location.origin).pathname;
        } catch {
            return path;
        }
    })();

    return pathname.replace(/^\/|\/$/g, "").toLowerCase();
}

function applyNavbarActivePath(path: string) {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    const currentPath = normalizeNavPath(path);
    const navLinks = navbar.querySelectorAll<HTMLElement>("[data-nav-path]");

    navLinks.forEach((link) => {
        const targetPath = normalizeNavPath(
            link instanceof HTMLAnchorElement
                ? link.href
                : link.dataset.navPath || "",
        );
        const isActive =
            targetPath === ""
                ? currentPath === ""
                : currentPath === targetPath || currentPath.startsWith(`${targetPath}/`);

        link.classList.toggle(NAVBAR_ACTIVE_CLASS, isActive);

        const activeTarget = link.querySelector<HTMLElement>("[data-nav-active-target]");
        activeTarget?.classList.toggle(NAVBAR_ACTIVE_CLASS, isActive);
    });

    navbar.querySelectorAll<HTMLElement>("[data-dropdown]").forEach((dropdown) => {
        const trigger = dropdown.querySelector<HTMLElement>("[data-dropdown-trigger]");
        if (!trigger) return;

        const hasActiveChild = !!dropdown.querySelector(
            `.dropdown-menu [data-nav-path].${NAVBAR_ACTIVE_CLASS}`,
        );
        trigger.classList.toggle(NAVBAR_ACTIVE_CLASS, hasActiveChild);
    });
}

function updateNavbarActiveLinks() {
    applyNavbarActivePath(window.location.pathname);
}

function setupNavbarActiveSync() {
    updateNavbarActiveLinks();

    document.getElementById("navbar")?.addEventListener("click", (event) => {
        const link = (event.target as Element | null)?.closest<HTMLAnchorElement>("[data-nav-path]");
        if (!link) return;
        applyNavbarActivePath(link.href);
    });

    document.addEventListener("swup:contentReplaced", updateNavbarActiveLinks);
    document.addEventListener("swup:content:replace", updateNavbarActiveLinks);
    document.addEventListener("astro:page-load", updateNavbarActiveLinks);
    window.addEventListener("popstate", updateNavbarActiveLinks);

    if (window.swup?.hooks) {
        window.swup.hooks.on("visit:start", (visit: { to?: { url?: string } }) => {
            if (visit.to?.url) applyNavbarActivePath(visit.to.url);
        });
        window.swup.hooks.on("page:view", updateNavbarActiveLinks);
        window.swup.hooks.on("visit:end", updateNavbarActiveLinks);
    } else {
        document.addEventListener("swup:enable", () => {
            if (!window.swup?.hooks) return;
            window.swup.hooks.on("visit:start", (visit: { to?: { url?: string } }) => {
                if (visit.to?.url) applyNavbarActivePath(visit.to.url);
            });
            window.swup.hooks.on("page:view", updateNavbarActiveLinks);
            window.swup.hooks.on("visit:end", updateNavbarActiveLinks);
            updateNavbarActiveLinks();
        }, { once: true });
    }
}

function loadButtonScript() {
    const settingBtn = document.getElementById("display-settings-switch");
    const menuBtn = document.getElementById("nav-menu-switch");
    const themeSwitchBtn = document.getElementById("scheme-switch");

    // 面板在点击时再查询：避免按钮已存在但面板尚未挂载（或被 swup 替换）时绑定失效。
    if (settingBtn) {
        settingBtn.onclick = function () {
            document
                .getElementById("display-setting")
                ?.classList.toggle("float-panel-closed");
        };
    }

    if (menuBtn) {
        menuBtn.onclick = function () {
            document
                .getElementById("nav-menu-panel")
                ?.classList.toggle("float-panel-closed");
        };
    }

    if (themeSwitchBtn) {
        themeSwitchBtn.onclick = function () {
            const html = document.documentElement;
            const LIGHT_MODE = "light";
            const DARK_MODE = "dark";

            const getStoredMode = () => {
                const stored =
                    html.getAttribute("data-theme-mode") ||
                    localStorage.getItem("theme") ||
                    LIGHT_MODE;
                return stored === DARK_MODE ? DARK_MODE : LIGHT_MODE;
            };

            const applyResolvedTheme = (resolvedIsDark: boolean) => {
                if (resolvedIsDark) html.classList.add("dark");
                else html.classList.remove("dark");

                const darkTheme = html.dataset.expressiveDarkTheme;
                const lightTheme = html.dataset.expressiveLightTheme;
                if (darkTheme && lightTheme) {
                    html.setAttribute("data-theme", resolvedIsDark ? darkTheme : lightTheme);
                }
            };

            const setMode = (mode: string) => {
                const applyMode = () => {
                    html.setAttribute("data-theme-mode", mode);
                    localStorage.setItem("theme", mode);
                    applyResolvedTheme(mode === DARK_MODE);
                    window.dispatchEvent(new CustomEvent("theme-change"));
                };

                if ((document as any).startViewTransition) {
                    html.classList.add("is-theme-transitioning", "use-view-transition");
                    const transition = (document as any).startViewTransition(applyMode);
                    transition.finished.finally(() => {
                        html.classList.remove("is-theme-transitioning", "use-view-transition");
                    });
                    return;
                }

                html.classList.add("is-theme-transitioning");
                applyMode();
                window.setTimeout(() => {
                    html.classList.remove("is-theme-transitioning");
                }, 180);
            };

            const current = getStoredMode();
            const next = current === LIGHT_MODE ? DARK_MODE : LIGHT_MODE;
            setMode(next);
        };
    }
}

setupNavbarActiveSync();
loadButtonScript();

// 为semifull模式添加滚动检测逻辑
function initSemifullScrollDetection() {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;

    const transparentMode = navbar.getAttribute('data-transparent-mode');
    if (transparentMode !== 'semifull') return;

    const isHomePage = navbar.getAttribute('data-is-home') === 'true';

    // 如果不是首页，移除滚动事件监听器并设置为半透明状态
    if (!isHomePage) {
        // 移除之前的滚动事件监听器（如果存在）
        if (window.semifullScrollHandler) {
            window.removeEventListener('scroll', window.semifullScrollHandler as () => void);
            window.semifullScrollHandler = undefined;
        }
        // 设置为半透明状态
        navbar.classList.add('scrolled');
        return;
    }

    // 移除现有的scrolled类，重置状态
    navbar.classList.remove('scrolled');

    let ticking = false;
    let isScrolled = false;
    const threshold = 50;

    function updateNavbarState() {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        // 只在状态变化时更新DOM，避免不必要的重排
        const shouldBeScrolled = scrollTop > threshold;
        if (shouldBeScrolled !== isScrolled) {
            isScrolled = shouldBeScrolled;
            navbar!.classList.toggle('scrolled', isScrolled);
        }
        ticking = false;
    }

    function requestTick() {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(updateNavbarState);
        }
    }

    // 移除之前的滚动事件监听器（如果存在）
    if (window.semifullScrollHandler) {
        window.removeEventListener('scroll', window.semifullScrollHandler as () => void);
    }

    // 保存新的事件处理器引用
    window.semifullScrollHandler = requestTick as unknown as (() => void);

    // 监听滚动事件
    window.addEventListener('scroll', requestTick, { passive: true });

    // 初始化状态
    updateNavbarState();
}

// 将函数暴露到全局对象，供页面切换时调用
window.initSemifullScrollDetection = initSemifullScrollDetection;

// 页面加载完成后初始化滚动检测
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSemifullScrollDetection);
} else {
    initSemifullScrollDetection();
}
</script>
