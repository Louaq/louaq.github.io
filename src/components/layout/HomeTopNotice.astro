---
import { Icon } from "astro-icon/components";
import type { HomeTopNoticeItem } from "@/types/config";

interface Props {
	items: HomeTopNoticeItem[];
}

const { items } = Astro.props;
---

<div class="home-top-notice-stack mt-3 mb-3 flex flex-col gap-2">
	{
		items.map((item, i) => {
			return (
				<div
					class:list={[
						"home-top-notice home-top-notice--theme rounded-md overflow-hidden",
					]}
					id={`home-top-notice-${i}`}
					role="region"
					aria-label={item.title || "站点通知"}
				>
					<div class="max-w-[var(--page-width)] mx-auto px-4 md:px-5 py-3 md:py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 text-[15px] md:text-[16px] leading-relaxed">
						<div class="flex flex-1 min-w-0 w-full items-center justify-start text-left">
							<div class="notice-title-body flex w-full min-w-0 max-w-full items-center gap-x-1.5 [overflow-wrap:anywhere]">
								{item.icon && (
									<span
										class="inline-flex shrink-0 items-center text-[1.05em] leading-none"
										aria-hidden="true"
									>
										<Icon
											name={item.icon}
											class="size-[1em] text-current [&_svg]:block"
											aria-hidden="true"
										/>
									</span>
								)}
								<div
									class="notice-text-flow min-w-0 flex-1 text-left [font-size:inherit] [line-height:inherit]"
								>
									{item.title && (
										<span class="font-bold tracking-tight text-[1.05em]">{item.title}</span>
									)}
									{item.title && ' '}
									<span class="notice-content-inline" set:html={item.content} />
								</div>
							</div>
						</div>
						{item.link?.enable && item.link.url?.trim() && (
							<div class="flex shrink-0 items-center justify-start sm:justify-end gap-2">
								<a
									href={item.link.url}
									target={item.link.external ? "_blank" : "_self"}
									rel={
										item.link.external ? "noopener noreferrer" : undefined
									}
									class="btn-regular rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap active:scale-95 transition-transform"
								>
									{item.link.text}
								</a>
							</div>
						)}
					</div>
				</div>
			);
		})
	}
</div>

<script>
	function pruneLegacyDismissKeys() {
		try {
			const prefix = "homeTopNoticeDismissed:";
			const removable: string[] = [];
			for (let i = 0; i < localStorage.length; i++) {
				const k = localStorage.key(i);
				if (k && k.startsWith(prefix)) removable.push(k);
			}
			for (const k of removable) localStorage.removeItem(k);
		} catch (_e) {
			// localStorage 不可用时静默忽略
		}
	}

	pruneLegacyDismissKeys();
	document.addEventListener("DOMContentLoaded", pruneLegacyDismissKeys);
	document.addEventListener("swup:contentReplaced", pruneLegacyDismissKeys);
</script>

<style is:global>
	/* content 支持 HTML（如 <a href>）；样式与通知条文案色一致 */
	.notice-content-inline a {
		color: inherit;
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.18em;
		text-decoration-thickness: min(2px, 0.1em);
	}
	.notice-content-inline a:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 2px;
		border-radius: 2px;
	}
</style>
