---
import type { HomeTopNoticeItem, HomeTopNoticeTone } from "@/types/config";

interface Props {
	items: HomeTopNoticeItem[];
}

const { items } = Astro.props;

const toneClass: Record<HomeTopNoticeTone, string> = {
	info:
		"bg-sky-100 dark:bg-sky-950/85 text-sky-950 dark:text-sky-50 shadow-[0_1px_3px_-1px_rgb(14_116_144/0.12)]",
	warning:
		"bg-amber-100 dark:bg-amber-950/92 text-amber-950 dark:text-amber-50 shadow-[0_2px_6px_-1px_rgb(146_64_14/0.15)]",
	success:
		"bg-emerald-100 dark:bg-emerald-950/85 text-emerald-950 dark:text-emerald-50 shadow-[0_1px_3px_-1px_rgb(6_95_70/0.12)]",
	error:
		"bg-red-100 dark:bg-red-950/92 text-red-950 dark:text-red-50 shadow-[0_2px_6px_-1px_rgb(185_28_28/0.15)]",
	neutral:
		"bg-neutral-100 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 shadow-sm shadow-black/5 dark:shadow-none",
	tip:
		"bg-violet-100 dark:bg-violet-950/85 text-violet-950 dark:text-violet-50 shadow-[0_1px_3px_-1px_rgb(91_33_182/0.14)]",
	urgent:
		"bg-orange-100 dark:bg-orange-950/95 text-orange-950 dark:text-orange-50 shadow-[0_2px_8px_-1px_rgb(234_88_12/0.2)]",
};

function barToneClasses(type: HomeTopNoticeTone | undefined): string {
	const tone = type ?? "warning";
	return toneClass[tone] ?? toneClass.warning;
}
---

<div class="home-top-notice-stack mt-3 mb-3 flex flex-col gap-2">
	{
		items.map((item, i) => {
			const tone = item.type ?? "warning";
			return (
				<div
					class:list={[
						"home-top-notice rounded-md overflow-hidden",
						barToneClasses(tone),
					]}
					id={`home-top-notice-${i}`}
					role="region"
					aria-label={item.title || "站点通知"}
				>
					<div class="max-w-[var(--page-width)] mx-auto px-4 md:px-5 py-3 md:py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 text-[15px] md:text-[16px] leading-relaxed">
						<div class="flex flex-1 min-w-0 items-center justify-center sm:justify-start text-center sm:text-left">
							<div class="min-w-0">
								{item.title && (
									<span class="font-bold mr-1.5 tracking-tight text-[1.05em]">{item.title}</span>
								)}
								<span class="notice-content-inline" set:html={item.content} />
							</div>
						</div>
						{item.link?.enable && item.link.url?.trim() && (
							<div class="flex shrink-0 items-center justify-center sm:justify-end gap-2">
								<a
									href={item.link.url}
									target={item.link.external ? "_blank" : "_self"}
									rel={
										item.link.external ? "noopener noreferrer" : undefined
									}
									class="btn-regular rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap active:scale-95 transition-transform"
								>
									{item.link.text}
								</a>
							</div>
						)}
					</div>
				</div>
			);
		})
	}
</div>

<script>
	function pruneLegacyDismissKeys() {
		try {
			const prefix = "homeTopNoticeDismissed:";
			const removable: string[] = [];
			for (let i = 0; i < localStorage.length; i++) {
				const k = localStorage.key(i);
				if (k && k.startsWith(prefix)) removable.push(k);
			}
			for (const k of removable) localStorage.removeItem(k);
		} catch (_e) {
			// localStorage 不可用时静默忽略
		}
	}

	pruneLegacyDismissKeys();
	document.addEventListener("DOMContentLoaded", pruneLegacyDismissKeys);
	document.addEventListener("swup:contentReplaced", pruneLegacyDismissKeys);
</script>

<style is:global>
	/* content 支持 HTML（如 <a href>）；样式与通知条文案色一致 */
	.notice-content-inline a {
		color: inherit;
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.18em;
		text-decoration-thickness: min(2px, 0.1em);
	}
	.notice-content-inline a:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 2px;
		border-radius: 2px;
	}
</style>
