---
import { Icon } from "astro-icon/components";
import RandomCoverImage from "@/components/common/RandomCoverImage.astro";

export interface CarouselSlide {
	href: string;
	title: string;
	image: string;
	basePath?: string;
	seed?: string;
	openInNewTab?: boolean;
	meta?: { icon: string; text: string }[];
}

interface Props {
	slides: CarouselSlide[];
	autoplayMs?: number;
}

const { slides, autoplayMs = 5000 } = Astro.props;
const safeAutoplayMs = Math.max(0, autoplayMs);
---

{
	slides.length > 0 && (
		<section
			class="home-carousel card-base rounded-[var(--radius-large)] overflow-hidden onload-animation mb-4"
			data-home-carousel
			data-autoplay={safeAutoplayMs}
			aria-label="首页精选轮播"
		>
			<div class="carousel-track-wrap relative overflow-hidden">
				<div class="carousel-track flex">
					{
						slides.map((slide, index) => {
							const finalImage = slide.image?.trim() || "";
							const hasImage = !!finalImage;
							const metaItems = slide.meta || [];
							const isExternal =
								slide.openInNewTab ??
								(/^https?:\/\//.test(slide.href) || slide.href.startsWith("//"));
							return (
								<article class="carousel-slide min-w-full">
									<a
										href={slide.href}
										class="carousel-slide-link group relative block h-[230px] md:h-[300px]"
										target={isExternal ? "_blank" : undefined}
										rel={isExternal ? "noopener noreferrer" : undefined}
									>
										{
											hasImage ? (
												<div class="carousel-media absolute inset-0">
													<RandomCoverImage
														src={finalImage}
														basePath={slide.basePath || "/"}
														alt={slide.title}
														class="h-full w-full object-cover"
														seed={slide.seed}
														preview={true}
														loading={index === 0 ? "eager" : "lazy"}
														deferSrc={index > 0}
													/>
												</div>
											) : (
												<div class="carousel-fallback absolute inset-0" />
											)
										}
										<div class="carousel-mask absolute inset-0" />
										<div class="carousel-content absolute inset-0 p-4 md:p-6">
											<h2 class="text-xl md:text-3xl font-bold leading-snug mb-2 line-clamp-2 text-white">
												{slide.title}
											</h2>
											<div class="flex items-center gap-3 text-white/85 text-sm mt-1 flex-wrap">
												{
													metaItems.map((item, index) => (
														<>
															{index > 0 && <span class="opacity-70">·</span>}
															<span class="inline-flex items-center gap-1.5">
																<Icon name={item.icon} class="text-base opacity-90" />
																{item.text}
															</span>
														</>
													))
												}
											</div>
										</div>
									</a>
								</article>
							);
						})
					}
				</div>
				{
					slides.length > 1 && (
						<>
							<button
								type="button"
								class="carousel-btn carousel-prev absolute left-3 top-1/2 -translate-y-1/2 h-9 w-9 rounded-full flex items-center justify-center"
								aria-label="上一张"
							>
								‹
							</button>
							<button
								type="button"
								class="carousel-btn carousel-next absolute right-3 top-1/2 -translate-y-1/2 h-9 w-9 rounded-full flex items-center justify-center"
								aria-label="下一张"
							>
								›
							</button>
							<div class="carousel-dots absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
								{
									slides.map((_slide, index) => (
										<button
											type="button"
											class="carousel-dot h-2.5 w-2.5 rounded-full"
											data-slide-to={index}
											aria-label={`跳转到第 ${index + 1} 张`}
										/>
									))
								}
							</div>
						</>
					)
				}
			</div>
		</section>
	)
}

<script is:inline data-astro-rerun>
	function setupCarousel(root) {
		const track = root.querySelector(".carousel-track");
		if (!track) return;
		const slides = Array.from(root.querySelectorAll(".carousel-slide"));
		const total = slides.length;
		if (total === 0) return;

		const dots = Array.from(root.querySelectorAll(".carousel-dot"));
		const prevBtn = root.querySelector(".carousel-prev");
		const nextBtn = root.querySelector(".carousel-next");
		const autoplayMs = Number(root.getAttribute("data-autoplay") || "0");

		let current = 0;
		let timer = null;
		let touchStartX = 0;
		let touchStartY = 0;
		let touchTracking = false;

		const loadSlideImage = (index) => {
			const slide = slides[index];
			if (!slide) return;
			const image = slide.querySelector("img[data-lazy-src]");
			if (!image) return;
			const lazySrc = image.getAttribute("data-lazy-src");
			if (!lazySrc) return;
			image.setAttribute("src", lazySrc);
			image.removeAttribute("data-lazy-src");
		};

		const render = () => {
			loadSlideImage(current);
			slides.forEach((slide, i) => {
				slide.classList.toggle("is-active", i === current);
			});
			dots.forEach((dot, i) => {
				dot.classList.toggle("is-active", i === current);
			});
		};

		const stop = () => {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		};

		const start = () => {
			stop();
			if (autoplayMs > 0 && total > 1) {
				timer = setInterval(() => {
					current = (current + 1) % total;
					render();
				}, autoplayMs);
			}
		};

		const goTo = (index) => {
			if (total <= 1) return;
			current = (index + total) % total;
			render();
			start();
		};

		prevBtn?.addEventListener("click", () => {
			goTo(current - 1);
		});
		nextBtn?.addEventListener("click", () => {
			goTo(current + 1);
		});
		dots.forEach((dot, i) => {
			dot.addEventListener("click", () => {
				goTo(i);
			});
		});

		root.addEventListener("mouseenter", stop);
		root.addEventListener("mouseleave", start);

		root.addEventListener(
			"touchstart",
			(event) => {
				if (total <= 1) return;
				const touch = event.touches[0];
				if (!touch) return;
				touchStartX = touch.clientX;
				touchStartY = touch.clientY;
				touchTracking = true;
				stop();
			},
			{ passive: true },
		);

		root.addEventListener(
			"touchend",
			(event) => {
				if (!touchTracking || total <= 1) return;
				touchTracking = false;
				const touch = event.changedTouches[0];
				if (!touch) {
					start();
					return;
				}
				const deltaX = touch.clientX - touchStartX;
				const deltaY = touch.clientY - touchStartY;
				const isHorizontalSwipe = Math.abs(deltaX) > 48 && Math.abs(deltaX) > Math.abs(deltaY) * 1.2;
				if (isHorizontalSwipe) {
					goTo(deltaX < 0 ? current + 1 : current - 1);
				} else {
					start();
				}
			},
			{ passive: true },
		);

		root.addEventListener("touchcancel", () => {
			touchTracking = false;
			start();
		});

		render();
		start();
	}

	function initHomeCarousel() {
		document.querySelectorAll("[data-home-carousel]").forEach((carousel) => {
			const el = carousel;
			if (el.dataset.inited === "true") return;
			el.dataset.inited = "true";
			setupCarousel(el);
		});
	}

	document.addEventListener("DOMContentLoaded", initHomeCarousel);
	document.addEventListener("astro:page-load", initHomeCarousel);
	window.addEventListener("pageshow", initHomeCarousel);
</script>

<style>
	.home-carousel .carousel-track {
		position: relative;
		height: 230px;
	}

	.home-carousel .carousel-track-wrap {
		border-radius: inherit;
		overflow: hidden;
		background: color-mix(in oklab, var(--card-bg) 82%, black 18%);
		touch-action: pan-y;
	}

	.home-carousel .carousel-slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.55s ease;
	}

	.home-carousel .carousel-slide.is-active {
		opacity: 1;
		pointer-events: auto;
	}

	.home-carousel .carousel-slide-link {
		border-radius: var(--radius-large);
		overflow: hidden;
	}

	.home-carousel .carousel-fallback {
		background:
			radial-gradient(circle at 20% 10%, color-mix(in oklab, var(--primary) 35%, transparent 65%) 0%, transparent 45%),
			radial-gradient(circle at 80% 85%, color-mix(in oklab, var(--primary) 25%, transparent 75%) 0%, transparent 35%),
			var(--card-bg);
	}

	.home-carousel .carousel-mask {
		background:
			linear-gradient(
				180deg,
				rgba(0, 0, 0, 0.12) 0%,
				rgba(0, 0, 0, 0.38) 50%,
				rgba(0, 0, 0, 0.7) 100%
			);
	}

	.home-carousel .carousel-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 100%;
		transform: translateY(4px);
		transition: transform 0.25s ease;
		padding-left: 3.2rem;
		padding-right: 3.2rem;
		padding-bottom: 3rem;
		text-align: center;
	}

	.home-carousel .carousel-content p {
		margin-left: auto;
		margin-right: auto;
	}

	.home-carousel .carousel-content > div {
		justify-content: center;
	}

	.home-carousel .carousel-btn {
		color: white;
		background: transparent;
		border: 0;
		backdrop-filter: none;
		font-size: 2.2rem;
		font-weight: 500;
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
		transition: transform 0.2s ease, color 0.2s ease;
	}

	.home-carousel .carousel-dot {
		width: 0.5rem;
		background: rgba(255, 255, 255, 0.55);
		transition: width 0.2s ease, transform 0.2s ease, background 0.2s ease;
	}

	.home-carousel .carousel-dot.is-active {
		width: 1.6rem;
		background: white;
		transform: scale(1);
	}

	@media (max-width: 768px) {
		.home-carousel .carousel-content {
			padding-left: 2.2rem;
			padding-right: 2.2rem;
			padding-bottom: 2.7rem;
		}

		.home-carousel .carousel-btn {
			height: 2rem;
			width: 2rem;
			font-size: 1.7rem;
		}
	}

	@media (min-width: 768px) {
		.home-carousel .carousel-track {
			height: 300px;
		}
	}
</style>
