---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import RandomCoverImage from "@/components/common/RandomCoverImage.astro";
import { processCoverImageSync } from "@/utils/image-utils";
import { getFileDirFromPath, getPostUrlBySlug } from "@/utils/url-utils";

interface Props {
	posts: CollectionEntry<"posts">[];
	autoplayMs?: number;
}

const { posts, autoplayMs = 5000 } = Astro.props;
const safeAutoplayMs = Math.max(0, autoplayMs);
---

{
	posts.length > 0 && (
		<section
			class="home-carousel card-base rounded-[var(--radius-large)] overflow-hidden onload-animation mb-4"
			data-home-carousel
			data-autoplay={safeAutoplayMs}
			aria-label="首页精选文章轮播"
		>
			<div class="carousel-track-wrap relative overflow-hidden">
				<div class="carousel-track flex">
					{
						posts.map((post) => {
							const image = processCoverImageSync(post.data.image, post.id);
							const carouselImage = post.data.homeCarouselImage?.trim() || "";
							const finalImage = carouselImage || image;
							const hasImage = !!finalImage;
							const publishedText = post.data.published.toLocaleDateString("zh-CN", {
								year: "numeric",
								month: "2-digit",
								day: "2-digit",
							});
							const metaItems = [
								{
									icon: "lucide:calendar-days",
									text: publishedText,
								},
								...(post.data.category?.trim()
									? [
											{
												icon: "lucide:folder",
												text: post.data.category.trim(),
											},
										]
									: []),
								...(post.data.tags || []).slice(0, 2).map((tag) => ({
									icon: "lucide:tag",
									text: `#${tag.trim()}`,
								})),
							];
							return (
								<article class="carousel-slide min-w-full">
									<a
										href={getPostUrlBySlug(post.id)}
										class="carousel-slide-link group relative block h-[230px] md:h-[300px]"
									>
										{
											hasImage ? (
												<div class="carousel-media absolute inset-0">
													<RandomCoverImage
														src={finalImage}
														basePath={getFileDirFromPath(post.filePath || "")}
														alt={post.data.title}
														class="h-full w-full object-cover"
														seed={post.id}
														preview={true}
													/>
												</div>
											) : (
												<div class="carousel-fallback absolute inset-0" />
											)
										}
										<div class="carousel-mask absolute inset-0" />
										<div class="carousel-content absolute inset-0 p-4 md:p-6">
											<h2 class="text-xl md:text-3xl font-bold leading-snug mb-2 line-clamp-2 text-white">
												{post.data.title}
											</h2>
											<div class="flex items-center gap-3 text-white/85 text-sm mt-1 flex-wrap">
												{
													metaItems.map((item, index) => (
														<>
															{index > 0 && <span class="opacity-70">·</span>}
															<span class="inline-flex items-center gap-1.5">
																<Icon name={item.icon} class="text-base opacity-90" />
																{item.text}
															</span>
														</>
													))
												}
											</div>
										</div>
									</a>
								</article>
							);
						})
					}
				</div>
				{
					posts.length > 1 && (
						<>
							<button
								type="button"
								class="carousel-btn carousel-prev absolute left-3 top-1/2 -translate-y-1/2 h-9 w-9 rounded-full flex items-center justify-center"
								aria-label="上一张"
							>
								‹
							</button>
							<button
								type="button"
								class="carousel-btn carousel-next absolute right-3 top-1/2 -translate-y-1/2 h-9 w-9 rounded-full flex items-center justify-center"
								aria-label="下一张"
							>
								›
							</button>
							<div class="carousel-dots absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
								{
									posts.map((_post, index) => (
										<button
											type="button"
											class="carousel-dot h-2.5 w-2.5 rounded-full"
											data-slide-to={index}
											aria-label={`跳转到第 ${index + 1} 张`}
										/>
									))
								}
							</div>
						</>
					)
				}
			</div>
		</section>
	)
}

<script>
	function setupCarousel(root: HTMLElement) {
		const track = root.querySelector(".carousel-track") as HTMLElement | null;
		if (!track) return;
		const slides = Array.from(root.querySelectorAll(".carousel-slide")) as HTMLElement[];
		const total = slides.length;
		if (total === 0) return;

		const dots = Array.from(root.querySelectorAll(".carousel-dot")) as HTMLButtonElement[];
		const prevBtn = root.querySelector(".carousel-prev") as HTMLButtonElement | null;
		const nextBtn = root.querySelector(".carousel-next") as HTMLButtonElement | null;
		const autoplayMs = Number(root.getAttribute("data-autoplay") || "0");

		let current = 0;
		let timer: ReturnType<typeof setInterval> | null = null;

		const render = () => {
			slides.forEach((slide, i) => {
				slide.classList.toggle("is-active", i === current);
			});
			dots.forEach((dot, i) => {
				dot.classList.toggle("is-active", i === current);
			});
		};

		const stop = () => {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		};

		const start = () => {
			stop();
			if (autoplayMs > 0 && total > 1) {
				timer = setInterval(() => {
					current = (current + 1) % total;
					render();
				}, autoplayMs);
			}
		};

		prevBtn?.addEventListener("click", () => {
			if (total <= 1) return;
			current = (current - 1 + total) % total;
			render();
			start();
		});
		nextBtn?.addEventListener("click", () => {
			if (total <= 1) return;
			current = (current + 1) % total;
			render();
			start();
		});
		dots.forEach((dot, i) => {
			dot.addEventListener("click", () => {
				current = i;
				render();
				start();
			});
		});

		root.addEventListener("mouseenter", stop);
		root.addEventListener("mouseleave", start);

		render();
		start();
	}

	function initHomeCarousel() {
		document.querySelectorAll("[data-home-carousel]").forEach((carousel) => {
			const el = carousel as HTMLElement;
			if (el.dataset.inited === "true") return;
			el.dataset.inited = "true";
			setupCarousel(el);
		});
	}

	document.addEventListener("DOMContentLoaded", initHomeCarousel);
	document.addEventListener("astro:page-load", initHomeCarousel);
</script>

<style>
	.home-carousel .carousel-track {
		position: relative;
		height: 230px;
	}

	.home-carousel .carousel-track-wrap {
		border-radius: inherit;
		overflow: hidden;
		background: color-mix(in oklab, var(--card-bg) 82%, black 18%);
	}

	.home-carousel .carousel-slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.55s ease;
	}

	.home-carousel .carousel-slide.is-active {
		opacity: 1;
		pointer-events: auto;
	}

	.home-carousel .carousel-slide-link {
		border-radius: var(--radius-large);
		overflow: hidden;
	}

	.home-carousel .carousel-fallback {
		background:
			radial-gradient(circle at 20% 10%, color-mix(in oklab, var(--primary) 35%, transparent 65%) 0%, transparent 45%),
			radial-gradient(circle at 80% 85%, color-mix(in oklab, var(--primary) 25%, transparent 75%) 0%, transparent 35%),
			var(--card-bg);
	}

	.home-carousel .carousel-mask {
		background:
			linear-gradient(
				180deg,
				rgba(0, 0, 0, 0.12) 0%,
				rgba(0, 0, 0, 0.38) 50%,
				rgba(0, 0, 0, 0.7) 100%
			);
	}

	.home-carousel .carousel-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 100%;
		transform: translateY(4px);
		transition: transform 0.25s ease;
		padding-left: 3.2rem;
		padding-right: 3.2rem;
		padding-bottom: 3rem;
		text-align: center;
	}

	.home-carousel .carousel-content p {
		margin-left: auto;
		margin-right: auto;
	}

	.home-carousel .carousel-content > div {
		justify-content: center;
	}

	.home-carousel .carousel-btn {
		color: white;
		background: transparent;
		border: 0;
		backdrop-filter: none;
		font-size: 2.2rem;
		font-weight: 500;
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
		transition: transform 0.2s ease, color 0.2s ease;
	}

	.home-carousel .carousel-dot {
		width: 0.5rem;
		background: rgba(255, 255, 255, 0.55);
		transition: width 0.2s ease, transform 0.2s ease, background 0.2s ease;
	}

	.home-carousel .carousel-dot.is-active {
		width: 1.6rem;
		background: white;
		transform: scale(1);
	}

	@media (max-width: 768px) {
		.home-carousel .carousel-content {
			padding-left: 2.2rem;
			padding-right: 2.2rem;
			padding-bottom: 2.7rem;
		}

		.home-carousel .carousel-btn {
			height: 2rem;
			width: 2rem;
			font-size: 1.7rem;
		}
	}

	@media (min-width: 768px) {
		.home-carousel .carousel-track {
			height: 300px;
		}
	}
</style>
