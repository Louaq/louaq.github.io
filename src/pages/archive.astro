---
import ArchivePanel from "@components/controls/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@/utils/content-utils";
import { siteConfig } from "@/config/siteConfig";

const sortedPostsList = await getSortedPostsList();
const archivePageSize = siteConfig.pagination.archivePageSize ?? 20;
---

<MainGridLayout title={i18n(I18nKey.archive)}>
  <ArchivePanel sortedPosts={sortedPostsList} pageSize={archivePageSize} client:only="svelte" />
</MainGridLayout>