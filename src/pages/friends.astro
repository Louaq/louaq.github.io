---
import { getEntry, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import Icon from "@components/common/Icon.astro";
import Markdown from "@components/common/Markdown.astro";
import { Icon as AstroIcon } from "astro-icon/components";
import {
	commentConfig,
	friendsPageConfig,
	getEnabledFriends,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";


// 检查页面是否启用
if (!siteConfig.pages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

const { Content } = await render(friendsPost);


// 检查评论系统是否启用
const isCommentEnabled =
	commentConfig?.type &&
	commentConfig.type !== "none" &&
	friendsPageConfig.showComment !== false;

// 使用配置文件中的友链数据，按权重排序
const items = getEnabledFriends();
const allTags = [...new Set(items.flatMap((item) => item.tags || []))].sort();

// 页面标题和描述
const title = friendsPageConfig.title || i18n(I18nKey.friends);
const description =
	friendsPageConfig.description || i18n(I18nKey.friendsDescription);
---

<MainGridLayout title={title} description={description}>
  <div
    class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述（与留言页标题结构一致） -->
      <div class="mb-4">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-[var(--primary)] flex items-center justify-center text-white dark:text-black/70">
            <Icon icon="material-symbols:group" class="text-[1.5rem]"></Icon>
          </div>
          <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </h1>
        </div>
        {
          description && (
            <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
              {description}
            </p>
          )
        }
      </div>

      <!-- 搜索框 -->
      {items.length > 0 && (
        <div class="friend-search-wrapper mb-4">
          <div class="friend-search-input-wrap">
            <Icon icon="material-symbols:search" class="friend-search-icon" />
            <input
              type="text"
              class="friend-search-input"
              placeholder={i18n(I18nKey.searchTypeSomething)}
              aria-label={i18n(I18nKey.search)}
            />
          </div>
        </div>
      )}

      <!-- 标签筛选 -->
      {
        items.length > 0 && (
          <friend-filter class="flex flex-wrap gap-2 mb-6">
            <button
              data-tag="all"
              class="friend-tag-btn friend-tag-btn-active px-3 py-1.5 rounded-lg text-white transition-colors duration-200 text-sm font-medium"
            >
              {i18n(I18nKey.all)}
            </button>
            {allTags.map((tag) => (
              <button
                data-tag={tag}
                class="friend-tag-btn px-3 py-1.5 rounded-lg transition-colors duration-200 text-sm font-medium"
              >
                {tag}
              </button>
            ))}
          </friend-filter>
        )
      }

      <div class="friends-grid my-4">
        {
          items.map((item) => (
            <a
              href={item.siteurl}
              target="_blank"
              rel="noopener noreferrer"
              data-tags={item.tags?.join(",")}
              data-title={item.title}
              data-desc={item.desc}
              class="friend-card group flex items-center gap-3 p-2.5 rounded-xl border border-(--line-divider) hover:border-(--primary) hover:bg-(--card-bg) transition-all duration-300 hover:shadow-lg relative overflow-hidden"
            >
              {/* 背景装饰 - 仅悬停显示 */}
              <div class="absolute inset-0 bg-(--primary) opacity-0 group-hover:opacity-5 transition-opacity duration-300 pointer-events-none" />

              {/* 头像 */}
              <div class="relative w-16 h-16 shrink-0 rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-800 border border-black/5 dark:border-white/5 group-hover:scale-105 transition-transform duration-300">
                <img
                  src={item.imgurl}
                  alt={item.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>

              {/* 内容 */}
              <div class="grow min-w-0 flex flex-col justify-center gap-0.5">
                <div class="flex items-center justify-between">
                  <div class="font-bold text-base text-neutral-900 dark:text-neutral-100 group-hover:text-(--primary) transition-colors truncate pr-4">
                    {item.title}
                  </div>
                  {/* 外部链接图标 */}
                  <AstroIcon
                    name="material-symbols:arrow-outward-rounded"
                    class="text-(--primary) text-lg opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
                  />
                </div>

                <div
                  class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-1"
                  title={item.desc}
                >
                  {item.desc}
                </div>

                {/* 标签 */}
                <div class="flex flex-wrap gap-1 mt-1">
                  {item.tags && item.tags.length > 0
                    ? item.tags
                        .slice(0, 3)
                        .map((tag) => (
                          <span class="text-[0.65rem] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 transition-colors duration-300">
                            {tag}
                          </span>
                        ))
                    : null}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  {friendsPageConfig.showCustomContent !== false && (
    <div class="mt-4 card-base z-10 px-9 py-6 relative w-full">
      <Markdown class="">
        <Content />
      </Markdown>
    </div>
  )}

  <!-- 评论区 -->
  {isCommentEnabled && (
    <div class="mt-4">
      <Comment post={friendsPost} customPath="/friends/" />
    </div>
  )}

  <script slot="head" is:inline>
    if (!customElements.get("friend-filter")) {
      class FriendFilter extends HTMLElement {
        constructor() {
          super();
          this.applyFilters = this.applyFilters.bind(this);
        }

        connectedCallback() {
          this.addEventListener("click", this.handleClick);
          const container = this.closest(".card-base");
          if (container) {
            const searchInput = container.querySelector(".friend-search-input");
            if (searchInput) {
              searchInput.addEventListener("input", this.applyFilters);
              searchInput.addEventListener("keyup", this.applyFilters);
            }
          }
        }

        disconnectedCallback() {
          this.removeEventListener("click", this.handleClick);
          const container = this.closest(".card-base");
          if (container) {
            const searchInput = container.querySelector(".friend-search-input");
            if (searchInput) {
              searchInput.removeEventListener("input", this.applyFilters);
              searchInput.removeEventListener("keyup", this.applyFilters);
            }
          }
        }

        handleClick(e) {
          const target = e.target;
          const button = target.closest("button");
          if (!button) return;

          const filters = this.querySelectorAll("button");
          filters.forEach((f) => {
            f.classList.remove("friend-tag-btn-active");
            if (f === button) f.classList.add("friend-tag-btn-active");
          });
          this.applyFilters();
        }

        applyFilters() {
          const container = this.closest(".card-base");
          if (!container) return;

          const searchInput = container.querySelector(".friend-search-input");
          const activeBtn = this.querySelector(".friend-tag-btn-active");
          const selectedTag = activeBtn?.dataset.tag || "all";
          const query = (searchInput?.value || "").trim().toLowerCase();

          const cards = container.querySelectorAll(".friend-card");
          cards.forEach((cardEl) => {
            const tags = (cardEl.dataset.tags || "").split(",").filter(Boolean);
            const title = (cardEl.dataset.title || "").toLowerCase();
            const desc = (cardEl.dataset.desc || "").toLowerCase();

            const tagMatch = selectedTag === "all" || tags.includes(selectedTag);
            const searchMatch =
              !query ||
              title.includes(query) ||
              desc.includes(query) ||
              tags.some((t) => t.toLowerCase().includes(query));

            if (tagMatch && searchMatch) {
              cardEl.style.display = "";
              cardEl.classList.add("animate-fade-in-up");
            } else {
              cardEl.style.display = "none";
              cardEl.classList.remove("animate-fade-in-up");
            }
          });
        }
      }
      customElements.define("friend-filter", FriendFilter);
    }
  </script>

  <style is:global>
    .friend-search-input-wrap {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--line-divider);
      border-radius: var(--radius-large, 0.75rem);
      background: var(--card-bg);
      transition: border-color 0.2s;
    }
    .friend-search-input-wrap:focus-within {
      border-color: var(--primary);
      outline: none;
    }
    .friend-search-icon {
      color: var(--text-tertiary, #9ca3af);
      font-size: 1.25rem;
      flex-shrink: 0;
    }
    .friend-search-input {
      flex: 1;
      min-width: 0;
      border: none;
      background: transparent;
      font-size: 0.9375rem;
      color: var(--text-primary);
    }
    .friend-search-input::placeholder {
      color: var(--text-tertiary, #9ca3af);
    }
    .friend-search-input:focus {
      outline: none;
    }
    .friends-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .friend-tag-btn {
      background-color: var(--btn-regular-bg);
      color: var(--btn-content);
    }
    .friend-tag-btn:hover {
      background-color: var(--btn-regular-bg-hover);
    }
    .friend-tag-btn-active {
      background-color: var(--primary) !important;
      color: white !important;
    }
    .friend-tag-btn-active:hover {
      background-color: var(--primary) !important;
      opacity: 0.9;
    }
  </style>
</MainGridLayout>