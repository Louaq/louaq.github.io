---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@/utils/content-utils";
import { getTagUrl } from "@/utils/url-utils";

const tags = await getTagList();

// 按首字母分组
const groups: Map<string, typeof tags> = new Map();
for (const tag of tags) {
    const first = tag.name.trim().charAt(0).toUpperCase();
    const key = /^[A-Z]$/.test(first) ? first : "#";
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key)!.push(tag);
}

// 排序：字母 A-Z，非字母分组 "#" 放最后
const sortedKeys = [...groups.keys()].sort((a, b) => {
    if (a === "#") return 1;
    if (b === "#") return -1;
    return a.localeCompare(b);
});
---

<MainGridLayout title={i18n(I18nKey.tags)} description={i18n(I18nKey.tags)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <div class="flex items-baseline justify-between mb-8">
                <h1 class="text-3xl font-bold text-black/90 dark:text-white/90">
                    {i18n(I18nKey.tags)}
                </h1>
                <span class="text-sm text-black/40 dark:text-white/40">{tags.length} 个标签</span>
            </div>

            {tags.length === 0 ? (
                <p class="text-black/50 dark:text-white/50">{i18n(I18nKey.noTags)}</p>
            ) : (
                <div class="space-y-0 divide-y divide-black/5 dark:divide-white/5">
                    {sortedKeys.map((key) => (
                        <div class="flex gap-6 py-4">
                            <div class="w-8 shrink-0 pt-0.5">
                                <span class="text-2xl font-bold text-[var(--primary)] opacity-80 select-none">
                                    {key}
                                </span>
                            </div>
                            <div class="flex flex-wrap gap-x-1 gap-y-2 flex-1">
                                {groups.get(key)!.map((tag) => (
                                    <a
                                        href={getTagUrl(tag.name)}
                                        class="group inline-flex items-center gap-1 px-2 py-0.5 rounded text-sm text-black/65 dark:text-white/65 hover:text-[var(--primary)] hover:bg-[var(--primary)]/8 transition-all"
                                    >
                                        <span class="group-hover:text-[var(--primary)] transition-colors">
                                            {tag.name.trim()}
                                        </span>
                                        <span class="text-xs text-black/25 dark:text-white/25 group-hover:text-[var(--primary)]/50 transition-colors">
                                            {tag.count}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </div>
    </div>
</MainGridLayout>
