---
import { Icon } from "astro-icon/components";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@/utils/content-utils";
import { getTagUrl } from "@/utils/url-utils";

const tags = await getTagList();

/** 不按字母序：按文章数从多到少，同数再按名称稳定排序 */
const sortedTags = [...tags].sort((a, b) => {
	if (b.count !== a.count) return b.count - a.count;
	return a.name.localeCompare(b.name, undefined, { sensitivity: "base" });
});

/** 图1：柔和底色轮换（含深色模式近似色） */
const PASTEL_CHIP = [
	"bg-[#f9e4e8] text-[#555e67] hover:brightness-[0.97] dark:bg-rose-950/38 dark:text-rose-50 dark:hover:bg-rose-950/52",
	"bg-[#fdf6e3] text-[#555e67] hover:brightness-[0.97] dark:bg-amber-950/35 dark:text-amber-50 dark:hover:bg-amber-950/48",
	"bg-[#eee8f5] text-[#555e67] hover:brightness-[0.97] dark:bg-violet-950/38 dark:text-violet-100 dark:hover:bg-violet-950/50",
	"bg-[#e6f3f7] text-[#555e67] hover:brightness-[0.97] dark:bg-sky-950/38 dark:text-sky-50 dark:hover:bg-sky-950/50",
	"bg-[#e6f4ea] text-[#555e67] hover:brightness-[0.97] dark:bg-emerald-950/35 dark:text-emerald-50 dark:hover:bg-emerald-950/48",
	"bg-[#f0f0f0] text-[#555e67] hover:brightness-[0.97] dark:bg-neutral-800/55 dark:text-neutral-100 dark:hover:bg-neutral-800/70",
] as const;

/** 与标签名绑定，颜色不随排序变化 */
function pastelChipClass(tagName: string): string {
	let h = 0;
	for (let i = 0; i < tagName.length; i++) h = (h * 31 + tagName.charCodeAt(i)) | 0;
	const idx = Math.abs(h) % PASTEL_CHIP.length;
	return PASTEL_CHIP[idx];
}
---

<MainGridLayout title={i18n(I18nKey.tags)} description={i18n(I18nKey.tags)}>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
		<div class="card-base z-10 px-6 md:px-9 py-6 md:py-8 relative w-full">
			{tags.length === 0 ? (
				<p class="text-black/50 dark:text-white/50">{i18n(I18nKey.noTags)}</p>
			) : (
				<ul class="tags-page-cloud flex flex-wrap gap-2.5 md:gap-3 list-none m-0 p-0">
					{sortedTags.map((tag) => {
						const name = tag.name.trim();
						return (
							<li class="m-0 p-0">
								<a
									href={getTagUrl(tag.name)}
									class:list={[
										"tags-page-chip group inline-flex items-center gap-1.5 rounded px-3 py-1 text-sm no-underline",
										"transition-[filter,background-color] duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--primary)]",
										pastelChipClass(name),
									]}
								>
									<Icon
										name="material-symbols:tag-rounded"
										class="shrink-0 text-[1rem] text-current opacity-85"
										aria-hidden="true"
									/>
									<span class="font-normal tabular-nums leading-none">
										{name}({tag.count})
									</span>
								</a>
							</li>
						);
					})}
				</ul>
			)}
		</div>
	</div>
</MainGridLayout>
