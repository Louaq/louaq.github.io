---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@/utils/content-utils";
import { getTagUrl } from "@/utils/url-utils";

const tags = await getTagList();

/** 不按字母序：按文章数从多到少，同数再按名称稳定排序 */
const sortedTags = [...tags].sort((a, b) => {
	if (b.count !== a.count) return b.count - a.count;
	return a.name.localeCompare(b.name, undefined, { sensitivity: "base" });
});
---

<MainGridLayout title={i18n(I18nKey.tags)} description={i18n(I18nKey.tags)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <div class="flex items-baseline justify-between mb-8">
                <h1 class="text-3xl font-bold text-black/90 dark:text-white/90">
                    {i18n(I18nKey.tags)}
                </h1>
                <span class="text-sm text-black/40 dark:text-white/40">{tags.length} 个标签</span>
            </div>

            {tags.length === 0 ? (
                <p class="text-black/50 dark:text-white/50">{i18n(I18nKey.noTags)}</p>
            ) : (
                <div
                    class="grid w-full gap-2.5 md:gap-3 [grid-template-columns:repeat(auto-fit,minmax(min(100%,11rem),1fr))]"
                >
                    {sortedTags.map((tag) => (
                        <a
                            href={getTagUrl(tag.name)}
                            class:list={[
                                "tag-pill group flex w-full min-w-0 items-center gap-1.5 rounded-md pl-2.5 pr-1.5 py-1.5 text-sm",
                                "bg-[#eeeeee] dark:bg-white/[0.08]",
                                "transition-colors hover:bg-[#e4e4e4] dark:hover:bg-white/[0.12]",
                                "no-underline",
                            ]}
                        >
                            <span class="text-[#888888] dark:text-white/45 select-none shrink-0 transition-colors group-hover:text-[var(--primary)]">#</span>
                            <span class="min-w-0 flex-1 truncate text-[#444444] dark:text-neutral-100 font-medium leading-none">
                                {tag.name.trim()}
                            </span>
                            <span
                                class:list={[
                                    "inline-flex items-center justify-center min-w-[1.25rem] rounded px-1.5 py-0.5 text-xs tabular-nums shrink-0",
                                    "bg-white text-[#888888] dark:bg-neutral-800 dark:text-neutral-400",
                                    "border border-black/[0.06] dark:border-white/10",
                                ]}
                            >
                                {tag.count}
                            </span>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>
</MainGridLayout>
