---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCategoryList } from "@/utils/content-utils";

const categories = await getCategoryList();

const counts = categories.map((c) => c.count);
const minCount = counts.length ? Math.min(...counts) : 0;
const maxCount = counts.length ? Math.max(...counts) : 0;
/** 文章数越多字越大：在 minRem ~ maxRem 间按数量线性映射 */
function fontSizeForCount(count: number): string {
	if (maxCount === minCount) return "1rem";
	const t = (count - minCount) / (maxCount - minCount);
	const minRem = 0.8125;
	const maxRem = 1.375;
	return `${minRem + t * (maxRem - minRem)}rem`;
}
---

<MainGridLayout title={i18n(I18nKey.categories)} description={i18n(I18nKey.categories)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <h1 class="text-3xl font-bold text-black/90 dark:text-white/90 mb-6">
                {i18n(I18nKey.categories)}
            </h1>
            {categories.length === 0 ? (
                <p class="text-black/50 dark:text-white/50">{i18n(I18nKey.uncategorized)}</p>
            ) : (
                <div class="flex flex-wrap gap-x-5 gap-y-3">
                    {categories.map((cat) => (
                        <a
                            href={cat.url}
                            style={{ fontSize: fontSizeForCount(cat.count) }}
                            class="group inline-flex max-w-full items-baseline gap-[0.35em] font-medium text-black/80 underline-offset-4 transition-colors hover:text-[var(--primary)] dark:text-white/80"
                        >
                            <span class="truncate">{cat.name}</span>
                            <span class="shrink-0 text-[0.72em] font-semibold tabular-nums text-black/40 group-hover:text-[var(--primary)]/70 dark:text-white/45">
                                {cat.count}
                            </span>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>
</MainGridLayout>
