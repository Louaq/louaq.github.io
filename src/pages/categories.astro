---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCategoryList } from "@/utils/content-utils";

const categories = await getCategoryList();
---

<MainGridLayout title={i18n(I18nKey.categories)} description={i18n(I18nKey.categories)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <h1 class="text-3xl font-bold text-black/90 dark:text-white/90 mb-6">
                {i18n(I18nKey.categories)}
            </h1>
            {categories.length === 0 ? (
                <p class="text-black/50 dark:text-white/50">{i18n(I18nKey.uncategorized)}</p>
            ) : (
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    {categories.map((cat) => (
                        <a
                            href={cat.url}
                            class="group flex items-center justify-between rounded-[var(--radius-large)] border border-black/10 dark:border-white/10 px-5 py-4 transition-all hover:border-[var(--primary)]"
                        >
                            <span class="font-medium text-black/80 dark:text-white/80 group-hover:text-[var(--primary)] transition-colors">
                                {cat.name}
                            </span>
                            <span class="ml-3 rounded-full bg-black/5 dark:bg-white/10 px-2.5 py-0.5 text-sm font-semibold text-black/60 dark:text-white/60">
                                {cat.count}
                            </span>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>
</MainGridLayout>
