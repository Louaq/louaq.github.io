---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { getArchivePostsList } from "@/utils/content-utils";
import { getPostUrlBySlug } from "@/utils/url-utils";

const posts = await getArchivePostsList();

interface Group {
	year: number;
	posts: typeof posts;
}

const grouped: Record<number, typeof posts> = {};
for (const post of posts) {
	const year = post.published.getUTCFullYear();
	if (!grouped[year]) {
		grouped[year] = [];
	}
	grouped[year].push(post);
}
const groups: Group[] = Object.keys(grouped)
	.map(Number)
	.sort((a, b) => b - a)
	.map((year) => ({ year, posts: grouped[year] }));

function formatDate(date: Date) {
	const month = (date.getUTCMonth() + 1).toString().padStart(2, "0");
	const day = date.getUTCDate().toString().padStart(2, "0");
	return `${month}-${day}`;
}

function formatTags(tagList: string[]) {
	return tagList.map((t) => `#${t}`).join(" ");
}

const labelSingular = i18n(I18nKey.postCount);
const labelPlural = i18n(I18nKey.postsCount);
---
<MainGridLayout title={i18n(I18nKey.archive)}>
	<div class="card-base px-8 py-6" id="archive-list"
		data-label-singular={labelSingular} data-label-plural={labelPlural}>
		{groups.map((group, index) => (
			<details class="archive-year-group" data-year={group.year} open={index === 0}>
				<summary class="archive-year-summary flex flex-row w-full items-center h-15 -mx-2 px-2 rounded-lg cursor-pointer select-none transition-colors duration-150 hover:bg-(--btn-plain-bg-hover) active:bg-(--btn-plain-bg-active)">
					<div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75">
						{group.year}
					</div>
					<div class="w-[15%] md:w-[10%]">
						<div class="h-3 w-3 bg-none rounded-full outline-solid outline-(--primary) mx-auto -outline-offset-2 z-50 outline-3"></div>
					</div>
					<div class="w-[70%] md:w-[80%] transition text-left text-50 flex items-center gap-1">
						<span class="archive-year-count">
							{group.posts.length} {group.posts.length === 1 ? labelSingular : labelPlural}
						</span>
						<Icon name="material-symbols:keyboard-arrow-right"
							class="archive-year-chevron text-xl transition-transform duration-200"
							aria-hidden="true" />
					</div>
				</summary>
				<div class="archive-year-posts">
				{group.posts.map((post) => (
					<a
						href={getPostUrlBySlug(post.pathSlug)}
						aria-label={post.title}
						data-tags={post.tags.join(",")}
						data-category={post.category}
						class="group archive-row-link !block h-10 w-full rounded-lg text-black/75 dark:text-white/75
							transition-colors duration-150
							hover:bg-(--btn-plain-bg-hover) active:bg-(--btn-plain-bg-active)
							hover:text-[initial]"
					>
						<div class="flex flex-row justify-start items-center h-full">
							<div class="w-[15%] md:w-[10%] transition-colors text-sm text-right text-50">
								{formatDate(post.published)}
							</div>
							<div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
								<div class="transition-all mx-auto w-1 h-1 rounded group-hover:h-5
									bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-(--primary)
									outline outline-4 z-50
									outline-(--card-bg)
									group-hover:outline-(--btn-plain-bg-hover)
									group-active:outline-(--btn-plain-bg-active)"></div>
							</div>
							<div class="w-[70%] md:max-w-[65%] md:w-[65%] text-left font-bold transition-colors duration-150
								group-hover:text-(--primary)
								text-75 pr-8 whitespace-nowrap text-ellipsis overflow-hidden flex items-center gap-1">
								<span class="min-w-0 truncate">{post.title}</span>
								{post.password && (
									<Icon name="material-symbols:lock-outline"
										class="inline text-xl align-middle -translate-y-px text-inherit shrink-0"
										aria-label="加密" />
								)}
							</div>
							<div class="hidden md:block md:w-[15%] text-left text-sm transition-colors duration-150
								whitespace-nowrap text-ellipsis overflow-hidden text-30">
								{formatTags(post.tags)}
							</div>
						</div>
					</a>
				))}
				</div>
			</details>
		))}
	</div>
</MainGridLayout>
<style>
	.archive-year-summary::marker {
		content: "";
	}

	.archive-year-summary::-webkit-details-marker {
		display: none;
	}

	.archive-year-group[open] .archive-year-chevron {
		transform: rotate(90deg);
	}
</style>
<script>
	/**
	 * 年份分组的展开状态必须跨导航保留：swup 返回归档页时会用缓存的 HTML 重建 DOM，
	 * 若展开的年份重新折叠，页面高度会缩短到装不下原来的滚动位置，浏览器便把滚动
	 * 位置钳制回顶部，用户就回不到刚才浏览的文章处了。
	 *
	 * 这段脚本本身渲染在 swup 的 #swup-container 内，swup 用 DOMParser 解析目标页
	 * 再 cloneNode 换入 DOM，换入的 <script> 永远不会自动执行——所以这里的调用只覆盖
	 * “整页直接加载 /archive/”这一种情况；swup 单页导航后的重新初始化由
	 * Layout.astro 里持续存在的 content:replace 钩子调用同一个函数完成，
	 * 详见 src/utils/archive-init.ts 顶部注释。
	 */
	import { initArchivePage } from "@/utils/archive-init";
	initArchivePage();
</script>
