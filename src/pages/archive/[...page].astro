---
import type { GetStaticPaths } from "astro";
import ArchivePanel from "@components/controls/ArchivePanel.svelte";
import Pagination from "@/components/common/Pagination.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@/utils/content-utils";
import { siteConfig } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
	const sortedPostsList = await getSortedPostsList();
	const pageSize =
		siteConfig.pagination.archivePostsPerPage ??
		siteConfig.pagination.postsPerPage;
	return paginate(sortedPostsList, { pageSize });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainGridLayout title={i18n(I18nKey.archive)}>
  <ArchivePanel sortedPosts={page.data} client:only="svelte" />
  {
    page.lastPage > 1 && (
      <Pagination
        class="mx-auto mt-6 onload-animation"
        page={page}
        pageUrlRoot="archive"
      />
    )
  }
</MainGridLayout>
